      "html": "<style data-kid=\"0\">\n  @import url('https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;700&family=IBM+Plex+Sans:wght@400;500;600&display=swap');\n  @import url('https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css');\n\n  :root {\n    --color-gris: #565656;\n    --color-naranja: #f27405;\n    --color-lila: #9c9aee;\n    --color-white: #ffffff;\n    --neo-shadow: 6px 6px 0px 0px var(--color-gris);\n    --neo-shadow-hover: 2px 2px 0px 0px var(--color-gris);\n  }\n\n  body {\n    font-family: 'IBM Plex Sans', sans-serif;\n    background-color: var(--color-white);\n    color: var(--color-gris);\n    margin: 0;\n  }\n\n  .font-heading {\n    font-family: 'Space Grotesk', sans-serif;\n  }\n\n  .neo-border {\n    border: 2px solid var(--color-gris);\n  }\n\n  .neo-card {\n    background: var(--color-white);\n    border: 2px solid var(--color-gris);\n    box-shadow: var(--neo-shadow);\n    transition: all 0.2s ease;\n  }\n\n  .neo-card:hover {\n    transform: translate(4px, 4px);\n    box-shadow: var(--neo-shadow-hover);\n  }\n\n  .neo-btn-primary {\n    background: var(--color-naranja);\n    border: 2px solid var(--color-gris);\n    box-shadow: 4px 4px 0px 0px var(--color-gris);\n    transition: all 0.1s ease;\n  }\n\n  .neo-btn-primary:active {\n    transform: translate(2px, 2px);\n    box-shadow: 2px 2px 0px 0px var(--color-gris);\n  }\n\n  .active-nav-link {\n    background-color: var(--color-lila);\n    box-shadow: 3px 3px 0px 0px var(--color-gris);\n  }\n</style>\n\n<div class=\"min-h-screen flex flex-col\" data-kid=\"1\">\n  \n  <nav class=\"h-16 flex items-center justify-between px-8 bg-white border-b-2 border-[#565656] sticky top-0 z-50\" data-kid=\"2\">\n    <div class=\"flex items-center gap-3\" data-kid=\"3\">\n      <div class=\"w-10 h-10 bg-[#f27405] border-2 border-[#565656] flex items-center justify-center\" data-kid=\"4\">\n        <i class=\"ti ti-box-seam text-white text-2xl\" data-kid=\"5\"></i>\n      </div>\n      <span class=\"font-heading font-bold text-xl tracking-tight uppercase\" data-kid=\"6\">Inventario Pro</span>\n    </div>\n    \n    <div class=\"hidden md:flex items-center gap-6\" data-kid=\"7\">\n      <a href=\"#\" class=\"font-heading font-bold text-sm uppercase px-4 py-1.5 border-2 border-[#565656] active-nav-link\" data-kid=\"8\">Inicio</a>\n      <a href=\"#\" class=\"font-heading font-bold text-sm uppercase px-4 py-1.5 border-2 border-[#565656] hover:bg-[#9c9aee]/20 transition-colors\" data-kid=\"9\">Recepción</a>\n      <a href=\"#\" class=\"font-heading font-bold text-sm uppercase px-4 py-1.5 border-2 border-[#565656] hover:bg-[#9c9aee]/20 transition-colors\" data-kid=\"10\">Coordinador</a>\n      <a href=\"#\" class=\"font-heading font-bold text-sm uppercase px-4 py-1.5 border-2 border-[#565656] hover:bg-[#9c9aee]/20 transition-colors\" data-kid=\"11\">Calidad</a>\n    </div>\n\n    <div class=\"flex items-center gap-4\" data-kid=\"12\">\n      <button class=\"w-10 h-10 border-2 border-[#565656] flex items-center justify-center hover:bg-gray-50\" data-kid=\"13\">\n        <i class=\"ti ti-bell text-xl\" data-kid=\"14\"></i>\n      </button>\n      <div class=\"flex items-center gap-2 px-3 py-1 border-2 border-[#565656]\" data-kid=\"15\">\n        <img src=\"https://i.pravatar.cc/32?u=felipe\" alt=\"User\" class=\"w-6 h-6 border border-[#565656]\" data-kid=\"16\">\n        <span class=\"font-heading font-bold text-xs uppercase\" data-kid=\"17\">Admin</span>\n      </div>\n    </div>\n  </nav>\n\n  \n  <header class=\"py-16 px-8 max-w-7xl mx-auto w-full text-center\" data-kid=\"18\">\n    <h1 class=\"font-heading font-bold text-6xl md:text-7xl mb-6 uppercase leading-none\" data-kid=\"19\">\n      Gestión de <span class=\"bg-[#9c9aee] px-4 py-1 border-2 border-[#565656] inline-block -rotate-1\" data-kid=\"20\">Devoluciones</span>\n    </h1>\n    <p class=\"text-xl max-w-2xl mx-auto font-medium text-[#565656]/80\" data-kid=\"21\">\n      Optimiza el ciclo logístico con nuestro sistema de trazabilidad en tiempo real. Selecciona tu rol para comenzar.\n    </p>\n  </header>\n\n  \n  <main class=\"flex-grow px-8 pb-20 max-w-7xl mx-auto w-full\" data-kid=\"22\">\n    <div class=\"grid grid-cols-1 md:grid-cols-3 gap-10\" data-kid=\"23\">\n      \n      \n      <div class=\"neo-card p-8 flex flex-col items-center text-center group cursor-pointer\" data-kid=\"24\">\n        <div class=\"w-24 h-24 bg-[#f27405] border-2 border-[#565656] flex items-center justify-center mb-8 neo-shadow transition-all group-hover:bg-[#f27405]/90\" data-kid=\"25\">\n          <i class=\"ti ti-truck-loading text-5xl text-white\" data-kid=\"26\"></i>\n        </div>\n        <h2 class=\"font-heading font-bold text-3xl mb-4 uppercase\" data-kid=\"27\">Recepción</h2>\n        <p class=\"mb-8 flex-grow\" data-kid=\"28\">Registra nuevos ingresos, escanea códigos y documenta el estado inicial de la mercancía.</p>\n        <button class=\"neo-btn-primary w-full py-4 font-heading font-bold text-white uppercase tracking-widest text-sm\" data-kid=\"29\">\n          Ingresar Panel\n        </button>\n      </div>\n\n      \n      <div class=\"neo-card p-8 flex flex-col items-center text-center group cursor-pointer\" data-kid=\"30\">\n        <div class=\"w-24 h-24 bg-[#9c9aee] border-2 border-[#565656] flex items-center justify-center mb-8 neo-shadow transition-all group-hover:bg-[#9c9aee]/90\" data-kid=\"31\">\n          <i class=\"ti ti-clipboard-list text-5xl text-white\" data-kid=\"32\"></i>\n        </div>\n        <h2 class=\"font-heading font-bold text-3xl mb-4 uppercase\" data-kid=\"33\">Coordinador</h2>\n        <p class=\"mb-8 flex-grow\" data-kid=\"34\">Asigna recursos, gestiona el inventario en tránsito y supervisa los tiempos de procesamiento.</p>\n        <button class=\"neo-btn-primary w-full py-4 font-heading font-bold text-white uppercase tracking-widest text-sm\" data-kid=\"35\">\n          Gestionar Flujo\n        </button>\n      </div>\n\n      \n      <div class=\"neo-card p-8 flex flex-col items-center text-center group cursor-pointer\" data-kid=\"36\">\n        <div class=\"w-24 h-24 bg-[#565656] border-2 border-[#565656] flex items-center justify-center mb-8 neo-shadow transition-all group-hover:bg-[#565656]/90\" data-kid=\"37\">\n          <i class=\"ti ti-shield-check text-5xl text-white\" data-kid=\"38\"></i>\n        </div>\n        <h2 class=\"font-heading font-bold text-3xl mb-4 uppercase\" data-kid=\"39\">Calidad</h2>\n        <p class=\"mb-8 flex-grow\" data-kid=\"40\">Inspección técnica de productos, validación de garantías y decisión final de disposición.</p>\n        <button class=\"neo-btn-primary w-full py-4 font-heading font-bold text-white uppercase tracking-widest text-sm\" data-kid=\"41\">\n          Validar Calidad\n        </button>\n      </div>\n\n    </div>\n  </main>\n\n  \n  <footer class=\"bg-[#565656] text-white py-12 px-8\" data-kid=\"42\">\n    <div class=\"max-w-7xl mx-auto grid grid-cols-2 md:grid-cols-4 gap-8\" data-kid=\"43\">\n      <div class=\"border-l-2 border-[#9c9aee] pl-4\" data-kid=\"44\">\n        <div class=\"font-heading font-bold text-3xl\" data-kid=\"45\">1,284</div>\n        <div class=\"text-xs uppercase font-bold text-[#9c9aee]\" data-kid=\"46\">Total Procesados</div>\n      </div>\n      <div class=\"border-l-2 border-[#f27405] pl-4\" data-kid=\"47\">\n        <div class=\"font-heading font-bold text-3xl\" data-kid=\"48\">42</div>\n        <div class=\"text-xs uppercase font-bold text-[#f27405]\" data-kid=\"49\">Pendientes Hoy</div>\n      </div>\n      <div class=\"border-l-2 border-[#9c9aee] pl-4\" data-kid=\"50\">\n        <div class=\"font-heading font-bold text-3xl\" data-kid=\"51\">99.2%</div>\n        <div class=\"text-xs uppercase font-bold text-[#9c9aee]\" data-kid=\"52\">Eficiencia</div>\n      </div>\n      <div class=\"border-l-2 border-[#f27405] pl-4\" data-kid=\"53\">\n        <div class=\"font-heading font-bold text-3xl\" data-kid=\"54\">12m</div>\n        <div class=\"text-xs uppercase font-bold text-[#f27405]\" data-kid=\"55\">Tiempo Promedio</div>\n      </div>\n    </div>\n  </footer>\n</div>",
