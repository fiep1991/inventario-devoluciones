      "html": "<style data-kid=\"0\">\n  @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap');\n  @import url('https://cdn.jsdelivr.net/npm/@tabler/icons-webfont@latest/tabler-icons.min.css');\n\n  .font-inter { font-family: 'Inter', sans-serif; }\n  \n  .circuit-bg {\n    background-image: url('https://cdn.jsdelivr.net/npm/game-icons-transparent@latest/svgs/lorc/circuitry.svg');\n    background-size: 400px;\n    background-repeat: repeat;\n    opacity: 0.03;\n    pointer-events: none;\n  }\n</style>\n\n<div class=\"font-inter bg-[#f2f2f2] min-h-screen relative overflow-hidden\" data-kid=\"1\">\n  \n  <div class=\"absolute inset-0 circuit-bg\" data-kid=\"2\"></div>\n\n  \n  <nav class=\"bg-white border-b border-gray-200 sticky top-0 z-10\" data-kid=\"3\">\n    <div class=\"max-w-7xl mx-auto px-4 h-16 flex items-center justify-between\" data-kid=\"4\">\n      <div class=\"flex items-center gap-8\" data-kid=\"5\">\n        <div class=\"flex items-center gap-2\" data-kid=\"6\">\n          <div class=\"w-8 h-8 bg-[#a35fc1] rounded-md flex items-center justify-center text-white\" data-kid=\"7\">\n            <i class=\"ti ti-package text-xl\" data-kid=\"8\"></i>\n          </div>\n          <span class=\"font-bold text-gray-800 text-lg tracking-tight\" data-kid=\"9\">LogiTrack</span>\n        </div>\n        <div class=\"hidden md:flex items-center gap-6\" data-kid=\"10\">\n          <a href=\"#\" class=\"text-sm font-medium text-gray-500 hover:text-gray-900\" data-kid=\"11\">Dashboard</a>\n          <a href=\"#\" class=\"text-sm font-medium text-[#a35fc1] relative py-5\" data-kid=\"12\">\n            Recepción\n            <div class=\"absolute bottom-0 left-0 w-full h-0.5 bg-[#a35fc1]\" data-kid=\"13\"></div>\n          </a>\n          <a href=\"#\" class=\"text-sm font-medium text-gray-500 hover:text-gray-900\" data-kid=\"14\">Coordinador</a>\n          <a href=\"#\" class=\"text-sm font-medium text-gray-500 hover:text-gray-900\" data-kid=\"15\">Calidad</a>\n        </div>\n      </div>\n      <div class=\"flex items-center gap-4\" data-kid=\"16\">\n        <button class=\"p-2 text-gray-400 hover:text-gray-600\" data-kid=\"17\">\n          <i class=\"ti ti-bell text-xl\" data-kid=\"18\"></i>\n        </button>\n        <div class=\"flex items-center gap-2 pl-4 border-l border-gray-200\" data-kid=\"19\">\n          <div class=\"w-8 h-8 rounded-full bg-gray-200 flex items-center justify-center text-gray-600 font-bold text-xs\" data-kid=\"20\">JD</div>\n          <span class=\"text-sm font-medium text-gray-700\" data-kid=\"21\">Juan Delgado</span>\n        </div>\n      </div>\n    </div>\n  </nav>\n\n  \n  <main class=\"relative z-1 max-w-5xl mx-auto px-4 py-12\" data-kid=\"22\">\n    <div class=\"mb-8 flex items-center justify-between\" data-kid=\"23\">\n      <div data-kid=\"24\">\n        <h1 class=\"text-3xl font-bold text-gray-900\" data-kid=\"25\">Registro de Devolución</h1>\n        <p class=\"text-gray-500 mt-1\" data-kid=\"26\">Complete los pasos para ingresar una nueva devolución al sistema.</p>\n      </div>\n      <div class=\"flex gap-3\" data-kid=\"27\">\n        <button class=\"px-4 py-2 text-sm font-medium text-gray-700 bg-white border border-gray-300 rounded-lg hover:bg-gray-50 transition-colors\" data-kid=\"28\">\n          Cancelar\n        </button>\n        <button class=\"px-6 py-2 text-sm font-medium text-white bg-[#a35fc1] rounded-lg hover:bg-[#914db0] transition-colors shadow-sm\" data-kid=\"29\">\n          Guardar Registro\n        </button>\n      </div>\n    </div>\n\n    <div class=\"flex flex-col md:flex-row gap-8\" data-kid=\"30\">\n      \n      <aside class=\"w-full md:w-64 shrink-0\" data-kid=\"31\">\n        <div class=\"space-y-1\" data-kid=\"32\">\n          \n          <div class=\"group flex items-start gap-4 p-4 rounded-xl bg-white border border-gray-200 shadow-sm\" data-kid=\"33\">\n            <div class=\"w-8 h-8 rounded-full bg-[#a35fc1] text-white flex items-center justify-center font-bold text-sm shrink-0\" data-kid=\"34\">1</div>\n            <div data-kid=\"35\">\n              <p class=\"text-sm font-bold text-gray-900\" data-kid=\"36\">Datos Generales</p>\n              <p class=\"text-xs text-gray-500 mt-0.5 leading-relaxed\" data-kid=\"37\">Cliente y producto base de la devolución.</p>\n            </div>\n          </div>\n          \n          \n          <div class=\"ml-8 w-0.5 h-6 bg-gray-200\" data-kid=\"38\"></div>\n\n          \n          <div class=\"group flex items-start gap-4 p-4 rounded-xl hover:bg-white/50 transition-all border border-transparent\" data-kid=\"39\">\n            <div class=\"w-8 h-8 rounded-full bg-white border-2 border-gray-300 text-gray-400 flex items-center justify-center font-bold text-sm shrink-0\" data-kid=\"40\">2</div>\n            <div data-kid=\"41\">\n              <p class=\"text-sm font-bold text-gray-400\" data-kid=\"42\">Detalles Técnicos</p>\n              <p class=\"text-xs text-gray-400 mt-0.5 leading-relaxed\" data-kid=\"43\">Código, lote y estado físico.</p>\n            </div>\n          </div>\n\n          \n          <div class=\"ml-8 w-0.5 h-6 bg-gray-200\" data-kid=\"44\"></div>\n\n          \n          <div class=\"group flex items-start gap-4 p-4 rounded-xl hover:bg-white/50 transition-all border border-transparent\" data-kid=\"45\">\n            <div class=\"w-8 h-8 rounded-full bg-white border-2 border-gray-300 text-gray-400 flex items-center justify-center font-bold text-sm shrink-0\" data-kid=\"46\">3</div>\n            <div data-kid=\"47\">\n              <p class=\"text-sm font-bold text-gray-400\" data-kid=\"48\">Documentación</p>\n              <p class=\"text-xs text-gray-400 mt-0.5 leading-relaxed\" data-kid=\"49\">Registro fotográfico y notas.</p>\n            </div>\n          </div>\n        </div>\n      </aside>\n\n      \n      <div class=\"flex-1\" data-kid=\"50\">\n        <div class=\"bg-white rounded-2xl border border-gray-200 shadow-sm p-8\" data-kid=\"51\">\n          <div class=\"space-y-8\" data-kid=\"52\">\n            \n            <div class=\"flex items-center gap-2 pb-4 border-b border-gray-100\" data-kid=\"53\">\n              <i class=\"ti ti-info-circle text-[#a35fc1] text-xl\" data-kid=\"54\"></i>\n              <h2 class=\"text-lg font-bold text-gray-800\" data-kid=\"55\">1. Datos de la Devolución</h2>\n            </div>\n\n            <form class=\"space-y-6\" data-kid=\"56\">\n              <div class=\"grid grid-cols-1 md:grid-cols-2 gap-6\" data-kid=\"57\">\n                \n                <div class=\"space-y-1.5\" data-kid=\"58\">\n                  <label class=\"text-[11px] font-bold uppercase tracking-wider text-gray-400 ml-1\" data-kid=\"59\">Fecha de Ingreso</label>\n                  <div class=\"relative group\" data-kid=\"60\">\n                    <input type=\"date\" class=\"w-full h-11 bg-gray-50 border border-gray-200 rounded-lg px-4 text-sm text-gray-700 outline-none focus:bg-white focus:border-[#a35fc1] focus:ring-4 focus:ring-[#a35fc1]/10 transition-all\" data-kid=\"61\">\n                    <i class=\"ti ti-calendar absolute right-4 top-1/2 -translate-y-1/2 text-gray-400 pointer-events-none group-focus-within:text-[#a35fc1]\" data-kid=\"62\"></i>\n                  </div>\n                </div>\n\n                \n                <div class=\"space-y-1.5\" data-kid=\"63\">\n                  <label class=\"text-[11px] font-bold uppercase tracking-wider text-gray-400 ml-1\" data-kid=\"64\">Cliente / Proveedor</label>\n                  <input type=\"text\" placeholder=\"Ej. Colombina S.A.\" class=\"w-full h-11 bg-gray-50 border border-gray-200 rounded-lg px-4 text-sm text-gray-700 outline-none focus:bg-white focus:border-[#a35fc1] focus:ring-4 focus:ring-[#a35fc1]/10 transition-all\" data-kid=\"65\">\n                </div>\n\n                \n                <div class=\"md:col-span-2 space-y-1.5\" data-kid=\"66\">\n                  <label class=\"text-[11px] font-bold uppercase tracking-wider text-gray-400 ml-1\" data-kid=\"67\">Producto</label>\n                  <input type=\"text\" placeholder=\"Nombre completo del producto\" class=\"w-full h-11 bg-gray-50 border border-gray-200 rounded-lg px-4 text-sm text-gray-700 outline-none focus:bg-white focus:border-[#a35fc1] focus:ring-4 focus:ring-[#a35fc1]/10 transition-all\" data-kid=\"68\">\n                </div>\n              </div>\n\n              \n              <div class=\"pt-6\" data-kid=\"69\">\n                 <div class=\"flex items-center gap-2 pb-4 border-b border-gray-100 mb-6\" data-kid=\"70\">\n                  <i class=\"ti ti-settings text-gray-300 text-xl\" data-kid=\"71\"></i>\n                  <h2 class=\"text-lg font-bold text-gray-400\" data-kid=\"72\">2. Detalles Técnicos</h2>\n                </div>\n                \n                <div class=\"grid grid-cols-1 md:grid-cols-3 gap-6 opacity-60 pointer-events-none\" data-kid=\"73\">\n                  <div class=\"space-y-1.5\" data-kid=\"74\">\n                    <label class=\"text-[11px] font-bold uppercase tracking-wider text-gray-400 ml-1\" data-kid=\"75\">Código SAP</label>\n                    <input type=\"text\" placeholder=\"001.0000000\" class=\"w-full h-11 bg-gray-50 border border-gray-200 rounded-lg px-4 text-sm text-gray-700 outline-none\" data-kid=\"76\">\n                  </div>\n                  <div class=\"space-y-1.5\" data-kid=\"77\">\n                    <label class=\"text-[11px] font-bold uppercase tracking-wider text-gray-400 ml-1\" data-kid=\"78\">Lote</label>\n                    <input type=\"text\" placeholder=\"1010000000\" class=\"w-full h-11 bg-gray-50 border border-gray-200 rounded-lg px-4 text-sm text-gray-700 outline-none\" data-kid=\"79\">\n                  </div>\n                  <div class=\"space-y-1.5\" data-kid=\"80\">\n                    <label class=\"text-[11px] font-bold uppercase tracking-wider text-gray-400 ml-1\" data-kid=\"81\">Cantidad</label>\n                    <input type=\"number\" placeholder=\"0\" class=\"w-full h-11 bg-gray-50 border border-gray-200 rounded-lg px-4 text-sm text-gray-700 outline-none\" data-kid=\"82\">\n                  </div>\n                </div>\n              </div>\n\n              \n              <div class=\"pt-10 flex justify-end gap-3\" data-kid=\"83\">\n                <button type=\"button\" class=\"px-6 py-2.5 text-sm font-semibold text-white bg-[#a35fc1] rounded-lg hover:bg-[#914db0] transition-all flex items-center gap-2 shadow-sm\" data-kid=\"84\">\n                  Siguiente paso\n                  <i class=\"ti ti-chevron-right\" data-kid=\"85\"></i>\n                </button>\n              </div>\n            </form>\n          </div>\n        </div>\n      </div>\n    </div>\n  </main>\n</div>",
