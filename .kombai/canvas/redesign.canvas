    },
    "var_c358a58fb540": {
      "type": "variant",
      "label": "Recepción - Neo-Brutalist",
      "parentId": "var_b5b7acef1058",
      "themeId": null,
      "rect": {
        "x": 1380,
        "y": 0,
        "w": 529,
        "h": 878
      },
      "generation": {
        "prompt": "",
        "config": {}
      },
      "html": "<style data-kid=\"0\">\n  @import url('https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;700&display=swap');\n  @import url('https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css');\n\n  .font-space { font-family: 'Space Grotesk', sans-serif; }\n  \n  .neo-border { border: 2px solid #565656; }\n  .neo-shadow { shadow: 4px 4px 0px 0px #565656; }\n  .neo-shadow-lg { shadow: 8px 8px 0px 0px #565656; }\n  .neo-shadow-sm { shadow: 2px 2px 0px 0px #565656; }\n  \n  .accordion-content {\n    max-height: 0;\n    overflow: hidden;\n    transition: max-height 0.3s ease-out;\n  }\n  \n  .accordion-item.active .accordion-content {\n    max-height: 1000px;\n  }\n  \n  .accordion-item.active .ti-chevron-down {\n    transform: rotate(180deg);\n  }\n</style>\n\n<div class=\"font-space min-h-screen bg-[#f2f2f2] text-[#565656] flex flex-col\" data-kid=\"1\">\n  \n  <nav class=\"bg-white border-b-2 border-[#565656] py-4 px-8 flex justify-between items-center sticky top-0 z-50\" data-kid=\"2\">\n    <div class=\"flex items-center gap-3\" data-kid=\"3\">\n      <div class=\"w-10 h-10 bg-[#f27405] border-2 border-[#565656] flex items-center justify-center shadow-[2px_2px_0px_0px_#565656]\" data-kid=\"4\">\n        <i class=\"ti ti-box text-white text-xl\" data-kid=\"5\"></i>\n      </div>\n      <span class=\"text-xl font-bold uppercase tracking-tight\" data-kid=\"6\">Inventario <span class=\"text-[#f27405]\" data-kid=\"7\">Dev</span></span>\n    </div>\n    <div class=\"flex gap-6\" data-kid=\"8\">\n      <a href=\"#\" class=\"px-4 py-2 border-2 border-transparent hover:border-[#565656] hover:bg-[#9c9aee]/20 font-bold uppercase text-sm transition-all\" data-kid=\"9\">Inicio</a>\n      <a href=\"#\" class=\"px-4 py-2 border-2 border-[#565656] bg-[#9c9aee] font-bold uppercase text-sm shadow-[2px_2px_0px_0px_#565656]\" data-kid=\"10\">Recepción</a>\n      <a href=\"#\" class=\"px-4 py-2 border-2 border-transparent hover:border-[#565656] hover:bg-[#9c9aee]/20 font-bold uppercase text-sm transition-all\" data-kid=\"11\">Coordinador</a>\n      <a href=\"#\" class=\"px-4 py-2 border-2 border-transparent hover:border-[#565656] hover:bg-[#9c9aee]/20 font-bold uppercase text-sm transition-all\" data-kid=\"12\">Calidad</a>\n    </div>\n  </nav>\n\n  <main class=\"flex-grow container mx-auto px-4 py-12 flex flex-col lg:flex-row gap-12 items-start\" data-kid=\"13\">\n    \n    <div class=\"lg:w-1/3 flex flex-col gap-8\" data-kid=\"14\">\n      <div class=\"bg-white border-2 border-[#565656] p-6 shadow-[8px_8px_0px_0px_#565656]\" data-kid=\"15\">\n        <img src=\"https://images.unsplash.com/photo-1595886068978-59624dde48d1?auto=format&w=600&q=80&fit=crop\" alt=\"Clipboard and box illustration\" class=\"w-full aspect-square object-cover border-2 border-[#565656] mb-6\" decoding=\"async\" loading=\"lazy\" data-kid=\"16\">\n        <h1 class=\"text-4xl font-bold leading-none mb-4 uppercase italic\" data-kid=\"17\">Registro de <br data-kid=\"18\"><span class=\"text-[#f27405]\" data-kid=\"19\">Ingresos</span></h1>\n        <p class=\"text-lg font-medium leading-tight\" data-kid=\"20\">\n          Captura cada detalle de las devoluciones con precisión técnica. El sistema garantiza la trazabilidad desde el primer contacto.\n        </p>\n      </div>\n      \n      <div class=\"bg-[#9c9aee] border-2 border-[#565656] p-4 shadow-[4px_4px_0px_0px_#565656]\" data-kid=\"21\">\n        <div class=\"flex items-center gap-3\" data-kid=\"22\">\n          <i class=\"ti ti-info-circle text-2xl\" data-kid=\"23\"></i>\n          <p class=\"font-bold text-sm uppercase\" data-kid=\"24\">Recuerda adjuntar fotografías claras del estado del producto.</p>\n        </div>\n      </div>\n    </div>\n\n    \n    <div class=\"lg:w-2/3 w-full\" data-kid=\"25\">\n      <form class=\"flex flex-col gap-6\" data-kid=\"26\">\n        \n        \n        <div class=\"accordion-item active bg-white border-2 border-[#565656] shadow-[6px_6px_0px_0px_#565656]\" data-kid=\"27\">\n          <button type=\"button\" class=\"w-full flex items-center justify-between p-6 hover:bg-gray-50 transition-colors\" onclick=\"this.parentElement.classList.toggle('active')\" data-kid=\"28\">\n            <div class=\"flex items-center gap-4 text-left\" data-kid=\"29\">\n              <span class=\"text-5xl font-bold text-[#f27405] opacity-20\" data-kid=\"30\">01</span>\n              <div data-kid=\"31\">\n                <h3 class=\"text-xl font-bold uppercase\" data-kid=\"32\">Datos del Cliente</h3>\n                <p class=\"text-xs font-medium text-gray-500 uppercase tracking-widest\" data-kid=\"33\">Información de origen y tiempo</p>\n              </div>\n            </div>\n            <i class=\"ti ti-chevron-down text-2xl transition-transform\" data-kid=\"34\"></i>\n          </button>\n          \n          <div class=\"accordion-content border-t-2 border-[#565656]\" data-kid=\"35\">\n            <div class=\"p-6 grid grid-cols-1 md:grid-cols-2 gap-6\" data-kid=\"36\">\n              <div class=\"flex flex-col gap-2\" data-kid=\"37\">\n                <label class=\"text-sm font-bold uppercase tracking-wider\" data-kid=\"38\">Fecha de Recepción</label>\n                <input type=\"date\" class=\"border-2 border-[#565656] p-3 rounded-none focus:outline-none focus:bg-[#9c9aee]/10 font-medium\" data-kid=\"39\">\n              </div>\n              <div class=\"flex flex-col gap-2\" data-kid=\"40\">\n                <label class=\"text-sm font-bold uppercase tracking-wider\" data-kid=\"41\">Cliente / Proveedor</label>\n                <input type=\"text\" placeholder=\"Ej: Colombina S.A.\" class=\"border-2 border-[#565656] p-3 rounded-none focus:outline-none focus:ring-2 focus:ring-[#f27405] font-medium\" data-kid=\"42\">\n              </div>\n            </div>\n          </div>\n        </div>\n\n        \n        <div class=\"accordion-item bg-white border-2 border-[#565656] shadow-[6px_6px_0px_0px_#565656]\" data-kid=\"43\">\n          <button type=\"button\" class=\"w-full flex items-center justify-between p-6 hover:bg-gray-50 transition-colors\" onclick=\"this.parentElement.classList.toggle('active')\" data-kid=\"44\">\n            <div class=\"flex items-center gap-4 text-left\" data-kid=\"45\">\n              <span class=\"text-5xl font-bold text-[#f27405] opacity-20\" data-kid=\"46\">02</span>\n              <div data-kid=\"47\">\n                <h3 class=\"text-xl font-bold uppercase\" data-kid=\"48\">Detalle del Producto</h3>\n                <p class=\"text-xs font-medium text-gray-500 uppercase tracking-widest\" data-kid=\"49\">Identificación técnica del ítem</p>\n              </div>\n            </div>\n            <i class=\"ti ti-chevron-down text-2xl transition-transform\" data-kid=\"50\"></i>\n          </button>\n          \n          <div class=\"accordion-content border-t-2 border-[#565656]\" data-kid=\"51\">\n            <div class=\"p-6 grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6\" data-kid=\"52\">\n              <div class=\"flex flex-col gap-2 md:col-span-2 lg:col-span-3\" data-kid=\"53\">\n                <label class=\"text-sm font-bold uppercase tracking-wider\" data-kid=\"54\">Nombre del Producto</label>\n                <input type=\"text\" placeholder=\"Acido Estearico Triple Prensado\" class=\"border-2 border-[#565656] p-3 rounded-none focus:outline-none font-medium\" data-kid=\"55\">\n              </div>\n              <div class=\"flex flex-col gap-2\" data-kid=\"56\">\n                <label class=\"text-sm font-bold uppercase tracking-wider\" data-kid=\"57\">Código SAP</label>\n                <input type=\"text\" placeholder=\"001.0000000\" class=\"border-2 border-[#565656] p-3 rounded-none focus:outline-none font-medium\" data-kid=\"58\">\n              </div>\n              <div class=\"flex flex-col gap-2\" data-kid=\"59\">\n                <label class=\"text-sm font-bold uppercase tracking-wider\" data-kid=\"60\">Número de Lote</label>\n                <input type=\"text\" placeholder=\"1010000000\" class=\"border-2 border-[#565656] p-3 rounded-none focus:outline-none font-medium\" data-kid=\"61\">\n              </div>\n              <div class=\"flex flex-col gap-2\" data-kid=\"62\">\n                <label class=\"text-sm font-bold uppercase tracking-wider\" data-kid=\"63\">Cantidad (un)</label>\n                <input type=\"number\" placeholder=\"1\" class=\"border-2 border-[#565656] p-3 rounded-none focus:outline-none font-medium\" data-kid=\"64\">\n              </div>\n            </div>\n          </div>\n        </div>\n\n        \n        <div class=\"accordion-item bg-white border-2 border-[#565656] shadow-[6px_6px_0px_0px_#565656]\" data-kid=\"65\">\n          <button type=\"button\" class=\"w-full flex items-center justify-between p-6 hover:bg-gray-50 transition-colors\" onclick=\"this.parentElement.classList.toggle('active')\" data-kid=\"66\">\n            <div class=\"flex items-center gap-4 text-left\" data-kid=\"67\">\n              <span class=\"text-5xl font-bold text-[#f27405] opacity-20\" data-kid=\"68\">03</span>\n              <div data-kid=\"69\">\n                <h3 class=\"text-xl font-bold uppercase\" data-kid=\"70\">Estado y Evidencia</h3>\n                <p class=\"text-xs font-medium text-gray-500 uppercase tracking-widest\" data-kid=\"71\">Condición física y registro visual</p>\n              </div>\n            </div>\n            <i class=\"ti ti-chevron-down text-2xl transition-transform\" data-kid=\"72\"></i>\n          </button>\n          \n          <div class=\"accordion-content border-t-2 border-[#565656]\" data-kid=\"73\">\n            <div class=\"p-6 flex flex-col gap-6\" data-kid=\"74\">\n              <div class=\"flex flex-col gap-2\" data-kid=\"75\">\n                <label class=\"text-sm font-bold uppercase tracking-wider\" data-kid=\"76\">Estado de Ingreso</label>\n                <select class=\"border-2 border-[#565656] p-3 rounded-none focus:outline-none font-bold bg-white cursor-pointer\" data-kid=\"77\">\n                  <option data-kid=\"78\">Selecciona un estado...</option>\n                  <option data-kid=\"79\">Buen estado</option>\n                  <option data-kid=\"80\">Empaque dañado</option>\n                  <option data-kid=\"81\">Vencido</option>\n                  <option data-kid=\"82\">Diferencia de peso</option>\n                </select>\n              </div>\n              <div class=\"flex flex-col gap-2\" data-kid=\"83\">\n                <label class=\"text-sm font-bold uppercase tracking-wider\" data-kid=\"84\">Subir Imágenes (Multiselección)</label>\n                <div class=\"border-2 border-dashed border-[#565656] p-8 text-center bg-gray-50 hover:bg-[#9c9aee]/10 transition-colors cursor-pointer group\" data-kid=\"85\">\n                  <i class=\"ti ti-camera-plus text-4xl mb-2 group-hover:scale-110 transition-transform inline-block\" data-kid=\"86\"></i>\n                  <p class=\"font-bold text-sm uppercase\" data-kid=\"87\">Haz clic o arrastra las fotos aquí</p>\n                  <p class=\"text-xs mt-1\" data-kid=\"88\">Soportado: JPG, PNG (Max 5MB)</p>\n                  <input type=\"file\" class=\"hidden\" multiple data-kid=\"89\">\n                </div>\n              </div>\n            </div>\n          </div>\n        </div>\n\n        \n        <div class=\"accordion-item bg-white border-2 border-[#565656] shadow-[6px_6px_0px_0px_#565656]\" data-kid=\"90\">\n          <button type=\"button\" class=\"w-full flex items-center justify-between p-6 hover:bg-gray-50 transition-colors\" onclick=\"this.parentElement.classList.toggle('active')\" data-kid=\"91\">\n            <div class=\"flex items-center gap-4 text-left\" data-kid=\"92\">\n              <span class=\"text-5xl font-bold text-[#f27405] opacity-20\" data-kid=\"93\">04</span>\n              <div data-kid=\"94\">\n                <h3 class=\"text-xl font-bold uppercase\" data-kid=\"95\">Observaciones</h3>\n                <p class=\"text-xs font-medium text-gray-500 uppercase tracking-widest\" data-kid=\"96\">Notas adicionales relevantes</p>\n              </div>\n            </div>\n            <i class=\"ti ti-chevron-down text-2xl transition-transform\" data-kid=\"97\"></i>\n          </button>\n          \n          <div class=\"accordion-content border-t-2 border-[#565656]\" data-kid=\"98\">\n            <div class=\"p-6\" data-kid=\"99\">\n              <textarea placeholder=\"Describe cualquier anomalía o detalle específico observado durante la descarga...\" rows=\"4\" class=\"w-full border-2 border-[#565656] p-4 rounded-none focus:outline-none font-medium resize-none\" data-kid=\"100\"></textarea>\n            </div>\n          </div>\n        </div>\n\n        \n        <button type=\"submit\" class=\"w-full bg-[#f27405] border-2 border-[#565656] py-6 text-white text-2xl font-bold uppercase italic tracking-tighter shadow-[8px_8px_0px_0px_#565656] hover:translate-x-[-2px] hover:translate-y-[-2px] hover:shadow-[10px_10px_0px_0px_#565656] active:translate-x-[2px] active:translate-y-[2px] active:shadow-[2px_2px_0px_0px_#565656] transition-all\" data-kid=\"101\">\n          Finalizar Registro de Ingreso\n        </button>\n      </form>\n    </div>\n  </main>\n</div>",
