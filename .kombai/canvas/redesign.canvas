      "html": "<style data-kid=\"0\">\n  @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap');\n  @import url('https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css');\n\n  .font-sans {\n    font-family: 'Inter', sans-serif;\n  }\n</style>\n\n<div class=\"min-h-screen bg-[#f2f2f2] font-sans text-[#565656]\" data-kid=\"1\">\n  \n  <nav class=\"sticky top-0 z-50 w-full border-b border-neutral-200 bg-white shadow-xs\" data-kid=\"2\">\n    <div class=\"mx-auto flex h-16 max-w-7xl items-center justify-between px-4 sm:px-6 lg:px-8\" data-kid=\"3\">\n      \n      <div class=\"flex items-center gap-3\" data-kid=\"4\">\n        <div class=\"flex h-8 w-8 items-center justify-center rounded-lg bg-[#a35fc1] text-white\" data-kid=\"5\">\n          <i class=\"ti ti-box text-xl\" data-kid=\"6\"></i>\n        </div>\n        <span class=\"text-xl font-bold tracking-tight text-neutral-800\" data-kid=\"7\">Logi<span class=\"text-[#a35fc1]\" data-kid=\"8\">Flow</span></span>\n      </div>\n\n      \n      <div class=\"hidden h-full md:flex md:space-x-8\" data-kid=\"9\">\n        <a href=\"#\" class=\"inline-flex items-center border-b-2 border-[#a35fc1] px-1 pt-1 text-sm font-medium text-neutral-900 transition-colors\" data-kid=\"10\">\n          Dashboard\n        </a>\n        <a href=\"#\" class=\"inline-flex items-center border-b-2 border-transparent px-1 pt-1 text-sm font-medium text-neutral-500 hover:border-neutral-300 hover:text-neutral-700 transition-colors\" data-kid=\"11\">\n          Recepción\n        </a>\n        <a href=\"#\" class=\"inline-flex items-center border-b-2 border-transparent px-1 pt-1 text-sm font-medium text-neutral-500 hover:border-neutral-300 hover:text-neutral-700 transition-colors\" data-kid=\"12\">\n          Coordinador\n        </a>\n        <a href=\"#\" class=\"inline-flex items-center border-b-2 border-transparent px-1 pt-1 text-sm font-medium text-neutral-500 hover:border-neutral-300 hover:text-neutral-700 transition-colors\" data-kid=\"13\">\n          Calidad\n        </a>\n      </div>\n\n      \n      <div class=\"flex items-center gap-4\" data-kid=\"14\">\n        <button class=\"relative rounded-full p-2 text-neutral-400 hover:bg-neutral-50 hover:text-[#a35fc1] transition-all\" data-kid=\"15\">\n          <i class=\"ti ti-bell text-xl\" data-kid=\"16\"></i>\n          <span class=\"absolute top-2 right-2 flex h-2 w-2\" data-kid=\"17\">\n            <span class=\"absolute inline-flex h-full w-full animate-ping rounded-full bg-[#f27405] opacity-75\" data-kid=\"18\"></span>\n            <span class=\"relative inline-flex h-2 w-2 rounded-full bg-[#f27405]\" data-kid=\"19\"></span>\n          </span>\n        </button>\n        <div class=\"h-8 w-px bg-neutral-200\" data-kid=\"20\"></div>\n        <div class=\"flex items-center gap-3 cursor-pointer group\" data-kid=\"21\">\n          <div class=\"text-right hidden sm:block\" data-kid=\"22\">\n            <p class=\"text-xs font-semibold text-neutral-800\" data-kid=\"23\">Felipe Garcia</p>\n            <p class=\"text-[10px] text-neutral-500 uppercase tracking-wider font-medium\" data-kid=\"24\">Administrador</p>\n          </div>\n          <img class=\"h-9 w-9 rounded-full border border-neutral-200 p-0.5 group-hover:border-[#a35fc1] transition-all\" src=\"https://i.pravatar.cc/100?u=felipe\" alt=\"Avatar\" loading=\"lazy\" decoding=\"async\" data-kid=\"25\">\n        </div>\n      </div>\n    </div>\n  </nav>\n\n  \n  <main class=\"mx-auto max-w-7xl px-4 pt-12 pb-24 sm:px-6 lg:px-8\" data-kid=\"26\">\n    \n    <div class=\"mb-12\" data-kid=\"27\">\n      <h1 class=\"text-3xl font-extrabold tracking-tight text-neutral-900 sm:text-4xl\" data-kid=\"28\">\n        Gestión de Inventario y Devoluciones\n      </h1>\n      <p class=\"mt-3 max-w-2xl text-lg text-neutral-500\" data-kid=\"29\">\n        Bienvenido al panel central. Seleccione su rol para comenzar el procesamiento de mercancía.\n      </p>\n    </div>\n\n    \n    <div class=\"grid grid-cols-1 gap-8 sm:grid-cols-2 lg:grid-cols-3\" data-kid=\"30\">\n      \n      <div class=\"group relative flex flex-col overflow-hidden rounded-xl border border-neutral-200 bg-white shadow-sm transition-all duration-300 hover:-translate-y-2 hover:border-l-4 hover:border-l-[#a35fc1] hover:shadow-xl\" data-kid=\"31\">\n        <div class=\"p-8\" data-kid=\"32\">\n          <div class=\"mb-6 flex h-14 w-14 items-center justify-center rounded-xl bg-neutral-50 text-[#a35fc1] group-hover:bg-[#a35fc1]/10 transition-colors\" data-kid=\"33\">\n            <i class=\"ti ti-truck-loading text-3xl\" data-kid=\"34\"></i>\n          </div>\n          <h3 class=\"text-xl font-bold text-neutral-900\" data-kid=\"35\">Recepción</h3>\n          <p class=\"mt-4 text-sm leading-relaxed text-neutral-500\" data-kid=\"36\">\n            Ingreso de nuevas devoluciones al sistema. Registro de datos de cliente, producto y estado físico inicial.\n          </p>\n        </div>\n        <div class=\"mt-auto border-t border-neutral-50 p-6 bg-neutral-50/50\" data-kid=\"37\">\n          <button class=\"flex w-full items-center justify-center gap-2 rounded-lg bg-white px-4 py-2.5 text-sm font-semibold text-neutral-700 border border-neutral-200 shadow-sm group-hover:bg-[#a35fc1] group-hover:text-white group-hover:border-[#a35fc1] transition-all\" data-kid=\"38\">\n            Ingresar Recepción\n            <i class=\"ti ti-arrow-right text-lg\" data-kid=\"39\"></i>\n          </button>\n        </div>\n      </div>\n\n      \n      <div class=\"group relative flex flex-col overflow-hidden rounded-xl border border-neutral-200 bg-white shadow-sm transition-all duration-300 hover:-translate-y-2 hover:border-l-4 hover:border-l-[#a35fc1] hover:shadow-xl\" data-kid=\"40\">\n        <div class=\"p-8\" data-kid=\"41\">\n          <div class=\"mb-6 flex h-14 w-14 items-center justify-center rounded-xl bg-neutral-50 text-[#a35fc1] group-hover:bg-[#a35fc1]/10 transition-colors\" data-kid=\"42\">\n            <i class=\"ti ti-truck-delivery text-3xl\" data-kid=\"43\"></i>\n          </div>\n          <h3 class=\"text-xl font-bold text-neutral-900\" data-kid=\"44\">Coordinador</h3>\n          <p class=\"mt-4 text-sm leading-relaxed text-neutral-500\" data-kid=\"45\">\n            Gestión y seguimiento de lotes recibidos. Verificación técnica y asignación de prioridades para inspección.\n          </p>\n        </div>\n        <div class=\"mt-auto border-t border-neutral-50 p-6 bg-neutral-50/50\" data-kid=\"46\">\n          <button class=\"flex w-full items-center justify-center gap-2 rounded-lg bg-white px-4 py-2.5 text-sm font-semibold text-neutral-700 border border-neutral-200 shadow-sm group-hover:bg-[#a35fc1] group-hover:text-white group-hover:border-[#a35fc1] transition-all\" data-kid=\"47\">\n            Gestionar Lotes\n            <i class=\"ti ti-arrow-right text-lg\" data-kid=\"48\"></i>\n          </button>\n        </div>\n      </div>\n\n      \n      <div class=\"group relative flex flex-col overflow-hidden rounded-xl border border-neutral-200 bg-white shadow-sm transition-all duration-300 hover:-translate-y-2 hover:border-l-4 hover:border-l-[#a35fc1] hover:shadow-xl\" data-kid=\"49\">\n        <div class=\"p-8\" data-kid=\"50\">\n          <div class=\"mb-6 flex h-14 w-14 items-center justify-center rounded-xl bg-neutral-50 text-[#a35fc1] group-hover:bg-[#a35fc1]/10 transition-colors\" data-kid=\"51\">\n            <i class=\"ti ti-shield-check text-3xl\" data-kid=\"52\"></i>\n          </div>\n          <h3 class=\"text-xl font-bold text-neutral-900\" data-kid=\"53\">Control de Calidad</h3>\n          <p class=\"mt-4 text-sm leading-relaxed text-neutral-500\" data-kid=\"54\">\n            Decisión final sobre el destino de los productos: Aprobación para venta, análisis profundo o devolución a proveedor.\n          </p>\n        </div>\n        <div class=\"mt-auto border-t border-neutral-50 p-6 bg-neutral-50/50\" data-kid=\"55\">\n          <button class=\"flex w-full items-center justify-center gap-2 rounded-lg bg-white px-4 py-2.5 text-sm font-semibold text-neutral-700 border border-neutral-200 shadow-sm group-hover:bg-[#a35fc1] group-hover:text-white group-hover:border-[#a35fc1] transition-all\" data-kid=\"56\">\n            Ejecutar Inspección\n            <i class=\"ti ti-arrow-right text-lg\" data-kid=\"57\"></i>\n          </button>\n        </div>\n      </div>\n    </div>\n\n    \n    <div class=\"mt-20 grid grid-cols-2 gap-4 lg:grid-cols-4\" data-kid=\"58\">\n      <div class=\"rounded-xl border border-neutral-200 bg-white p-6 shadow-xs\" data-kid=\"59\">\n        <p class=\"text-sm font-medium text-neutral-400\" data-kid=\"60\">Pendientes Hoy</p>\n        <p class=\"mt-2 text-3xl font-bold text-neutral-800\" data-kid=\"61\">24</p>\n      </div>\n      <div class=\"rounded-xl border border-neutral-200 bg-white p-6 shadow-xs\" data-kid=\"62\">\n        <p class=\"text-sm font-medium text-neutral-400\" data-kid=\"63\">En Revisión</p>\n        <p class=\"mt-2 text-3xl font-bold text-neutral-800 text-[#f27405]\" data-kid=\"64\">12</p>\n      </div>\n      <div class=\"rounded-xl border border-neutral-200 bg-white p-6 shadow-xs\" data-kid=\"65\">\n        <p class=\"text-sm font-medium text-neutral-400\" data-kid=\"66\">Completados</p>\n        <p class=\"mt-2 text-3xl font-bold text-neutral-800\" data-kid=\"67\">158</p>\n      </div>\n      <div class=\"rounded-xl border border-neutral-200 bg-white p-6 shadow-xs\" data-kid=\"68\">\n        <p class=\"text-sm font-medium text-neutral-400\" data-kid=\"69\">Eficiencia</p>\n        <p class=\"mt-2 text-3xl font-bold text-neutral-800 text-emerald-500\" data-kid=\"70\">94.2%</p>\n      </div>\n    </div>\n  </main>\n</div>",
