      "html": "<style data-kid=\"0\">\n  @import url('https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;700&family=Poppins:wght@600;700&display=swap');\n  @import url('https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css');\n\n  body {\n    font-family: 'Nunito', sans-serif;\n    margin: 0;\n    padding: 0;\n  }\n\n  .glass-card {\n    background: rgba(255, 255, 255, 0.7);\n    backdrop-filter: blur(12px);\n    -webkit-backdrop-filter: blur(12px);\n    border: 1px solid rgba(255, 255, 255, 0.3);\n  }\n\n  .table-dashed-row {\n    border-bottom: 1.5px dashed rgba(163, 95, 193, 0.2);\n  }\n\n  .bg-blob {\n    position: fixed;\n    z-index: -1;\n    filter: blur(80px);\n    border-radius: 50%;\n  }\n</style>\n\n<div class=\"relative min-h-screen w-full overflow-hidden bg-[#f8f9ff] py-12 px-4 md:px-8\" data-kid=\"1\">\n  \n  <div class=\"bg-blob absolute -top-20 -left-20 h-96 w-96 bg-[#9c9aee]/20\" data-kid=\"2\"></div>\n  <div class=\"bg-blob absolute top-1/2 -right-20 h-80 w-80 -translate-y-1/2 bg-[#f27405]/10\" data-kid=\"3\"></div>\n  <div class=\"bg-blob absolute -bottom-20 left-1/4 h-72 w-72 bg-[#a35fc1]/15\" data-kid=\"4\"></div>\n\n  \n  <main class=\"mx-auto max-w-7xl\" data-kid=\"5\">\n    \n    <header class=\"mb-10 flex flex-col gap-6 md:flex-row md:items-center md:justify-between\" data-kid=\"6\">\n      <div data-kid=\"7\">\n        <h1 class=\"font-poppins text-4xl font-bold tracking-tight text-neutral-800\" data-kid=\"8\">Seguimiento Operativo</h1>\n        <p class=\"mt-2 text-lg text-neutral-500\" data-kid=\"9\">Gestión de devoluciones en etapas de Coordinación y Calidad.</p>\n      </div>\n      \n      <div class=\"glass-card flex items-center gap-4 rounded-2xl px-6 py-3 shadow-sm\" data-kid=\"10\">\n        <div class=\"flex flex-col items-end\" data-kid=\"11\">\n          <span class=\"text-sm font-semibold text-neutral-700\" data-kid=\"12\">Felipe Dev</span>\n          <span class=\"text-xs text-neutral-400 font-medium uppercase tracking-wider\" data-kid=\"13\">Administrador</span>\n        </div>\n        <img src=\"https://i.pravatar.cc/150?u=felipe\" alt=\"Avatar\" class=\"h-10 w-10 rounded-full border-2 border-white object-cover shadow-sm\" loading=\"lazy\" decoding=\"async\" data-kid=\"14\">\n      </div>\n    </header>\n\n    \n    <div class=\"mb-8 flex gap-2\" data-kid=\"15\">\n      <button class=\"glass-card rounded-full px-8 py-3 text-sm font-bold text-[#a35fc1] shadow-md transition-all hover:scale-105 active:scale-95\" data-kid=\"16\">\n        Revisiones Pendientes (Coordinador)\n      </button>\n      <button class=\"rounded-full bg-white/40 px-8 py-3 text-sm font-semibold text-neutral-500 transition-all hover:bg-white/60\" data-kid=\"17\">\n        Control de Calidad\n      </button>\n    </div>\n\n    \n    <section class=\"glass-card rounded-[32px] p-8 shadow-2xl shadow-[#a35fc1]/5\" data-kid=\"18\">\n      <div class=\"mb-6 flex items-center justify-between\" data-kid=\"19\">\n        <div class=\"flex items-center gap-4\" data-kid=\"20\">\n          <div class=\"h-3 w-3 rounded-full bg-amber-400 animate-pulse\" data-kid=\"21\"></div>\n          <h2 class=\"text-xl font-bold text-neutral-700\" data-kid=\"22\">Solicitudes en Recepción</h2>\n        </div>\n        <div class=\"flex items-center gap-2\" data-kid=\"23\">\n           <div class=\"relative\" data-kid=\"24\">\n             <i class=\"ti ti-search absolute left-3 top-1/2 -translate-y-1/2 text-neutral-400\" data-kid=\"25\"></i>\n             <input type=\"text\" placeholder=\"Buscar cliente o código...\" class=\"rounded-xl bg-white/50 py-2 pl-10 pr-4 text-sm border-transparent focus:ring-2 focus:ring-[#a35fc1]/20 outline-none transition-all w-64\" data-kid=\"26\">\n           </div>\n        </div>\n      </div>\n\n      <div class=\"overflow-x-auto\" data-kid=\"27\">\n        <table class=\"w-full text-left\" data-kid=\"28\">\n          <thead data-kid=\"29\">\n            <tr class=\"text-xs font-bold uppercase tracking-widest text-neutral-400\" data-kid=\"30\">\n              <th class=\"px-6 py-4\" data-kid=\"31\">Información del Envío</th>\n              <th class=\"px-6 py-4 text-center\" data-kid=\"32\">Producto / Código</th>\n              <th class=\"px-6 py-4 text-center\" data-kid=\"33\">Estado Inicial</th>\n              <th class=\"px-6 py-4 text-center\" data-kid=\"34\">Cantidad</th>\n              <th class=\"px-6 py-4 text-right\" data-kid=\"35\">Acciones de Verificación</th>\n            </tr>\n          </thead>\n          <tbody class=\"divide-y-0\" data-kid=\"36\">\n            \n            <tr class=\"table-dashed-row group transition-all hover:bg-white/40\" data-kid=\"37\">\n              <td class=\"px-6 py-6\" data-kid=\"38\">\n                <div class=\"flex items-center gap-4\" data-kid=\"39\">\n                  <div class=\"flex h-10 w-10 items-center justify-center rounded-xl bg-gradient-to-br from-[#a35fc1] to-[#9c9aee] text-white shadow-lg shadow-[#a35fc1]/20\" data-kid=\"40\">\n                    <i class=\"ti ti-user text-lg\" data-kid=\"41\"></i>\n                  </div>\n                  <div class=\"flex flex-col\" data-kid=\"42\">\n                    <span class=\"font-bold text-neutral-700\" data-kid=\"43\">Supermercado El Sol</span>\n                    <span class=\"text-xs font-medium text-neutral-400\" data-kid=\"44\">Ingreso: 15 Jun 2026</span>\n                  </div>\n                </div>\n              </td>\n              <td class=\"px-6 py-6 text-center\" data-kid=\"45\">\n                <div class=\"flex flex-col gap-1\" data-kid=\"46\">\n                  <span class=\"font-bold text-neutral-700\" data-kid=\"47\">Detergente Industrial 5L</span>\n                  <code class=\"text-[10px] font-bold text-[#a35fc1] bg-[#a35fc1]/10 px-2 py-0.5 rounded self-center\" data-kid=\"48\">COD-88219</code>\n                </div>\n              </td>\n              <td class=\"px-6 py-6 text-center\" data-kid=\"49\">\n                <span class=\"inline-flex items-center rounded-full bg-amber-100 px-3 py-1 text-xs font-bold text-amber-600\" data-kid=\"50\">\n                  Envase Dañado\n                </span>\n              </td>\n              <td class=\"px-6 py-6 text-center\" data-kid=\"51\">\n                <span class=\"text-lg font-bold text-neutral-700\" data-kid=\"52\">12</span>\n                <span class=\"text-xs text-neutral-400 ml-1 font-medium\" data-kid=\"53\">unidades</span>\n              </td>\n              <td class=\"px-6 py-6 text-right\" data-kid=\"54\">\n                <div class=\"flex items-center justify-end gap-2 opacity-0 group-hover:opacity-100 transition-opacity\" data-kid=\"55\">\n                   <button class=\"flex h-9 w-9 items-center justify-center rounded-xl bg-white text-[#a35fc1] shadow-sm hover:shadow-md transition-all\" data-kid=\"56\">\n                    <i class=\"ti ti-edit\" data-kid=\"57\"></i>\n                  </button>\n                  <button class=\"rounded-xl bg-gradient-to-r from-[#a35fc1] to-[#9c9aee] px-5 py-2 text-sm font-bold text-white shadow-lg shadow-[#a35fc1]/30 hover:shadow-xl transition-all\" data-kid=\"58\">\n                    Verificar\n                  </button>\n                </div>\n              </td>\n            </tr>\n\n            \n            <tr class=\"table-dashed-row group transition-all hover:bg-white/40\" data-kid=\"59\">\n              <td class=\"px-6 py-6\" data-kid=\"60\">\n                <div class=\"flex items-center gap-4\" data-kid=\"61\">\n                  <div class=\"flex h-10 w-10 items-center justify-center rounded-xl bg-gradient-to-br from-[#f27405] to-[#f27405]/70 text-white shadow-lg shadow-orange-200\" data-kid=\"62\">\n                    <i class=\"ti ti-building-store text-lg\" data-kid=\"63\"></i>\n                  </div>\n                  <div class=\"flex flex-col\" data-kid=\"64\">\n                    <span class=\"font-bold text-neutral-700\" data-kid=\"65\">Farmacia Integral</span>\n                    <span class=\"text-xs font-medium text-neutral-400\" data-kid=\"66\">Ingreso: 18 Jun 2026</span>\n                  </div>\n                </div>\n              </td>\n              <td class=\"px-6 py-6 text-center\" data-kid=\"67\">\n                <div class=\"flex flex-col gap-1\" data-kid=\"68\">\n                  <span class=\"font-bold text-neutral-700\" data-kid=\"69\">Alcohol Etílico 1L</span>\n                  <code class=\"text-[10px] font-bold text-[#a35fc1] bg-[#a35fc1]/10 px-2 py-0.5 rounded self-center\" data-kid=\"70\">COD-77120</code>\n                </div>\n              </td>\n              <td class=\"px-6 py-6 text-center\" data-kid=\"71\">\n                <span class=\"inline-flex items-center rounded-full bg-blue-100 px-3 py-1 text-xs font-bold text-blue-600\" data-kid=\"72\">\n                  Vencimiento Próximo\n                </span>\n              </td>\n              <td class=\"px-6 py-6 text-center\" data-kid=\"73\">\n                <span class=\"text-lg font-bold text-neutral-700\" data-kid=\"74\">45</span>\n                <span class=\"text-xs text-neutral-400 ml-1 font-medium\" data-kid=\"75\">unidades</span>\n              </td>\n              <td class=\"px-6 py-6 text-right\" data-kid=\"76\">\n                <div class=\"flex items-center justify-end gap-2 opacity-0 group-hover:opacity-100 transition-opacity\" data-kid=\"77\">\n                   <button class=\"flex h-9 w-9 items-center justify-center rounded-xl bg-white text-[#a35fc1] shadow-sm hover:shadow-md transition-all\" data-kid=\"78\">\n                    <i class=\"ti ti-edit\" data-kid=\"79\"></i>\n                  </button>\n                  <button class=\"rounded-xl bg-gradient-to-r from-[#a35fc1] to-[#9c9aee] px-5 py-2 text-sm font-bold text-white shadow-lg shadow-[#a35fc1]/30 hover:shadow-xl transition-all\" data-kid=\"80\">\n                    Verificar\n                  </button>\n                </div>\n              </td>\n            </tr>\n          </tbody>\n        </table>\n      </div>\n\n      \n      <div class=\"mt-8 flex items-center justify-between border-t border-white/40 pt-6\" data-kid=\"81\">\n        <div class=\"text-sm text-neutral-500\" data-kid=\"82\">\n          Mostrando <span class=\"font-bold text-neutral-700\" data-kid=\"83\">2</span> de <span class=\"font-bold text-neutral-700\" data-kid=\"84\">14</span> devoluciones pendientes.\n        </div>\n        <div class=\"flex gap-2\" data-kid=\"85\">\n          <button class=\"glass-card flex h-8 w-8 items-center justify-center rounded-lg text-neutral-400 hover:text-[#a35fc1] transition-all\" data-kid=\"86\"><i class=\"ti ti-chevron-left\" data-kid=\"87\"></i></button>\n          <button class=\"glass-card flex h-8 w-8 items-center justify-center rounded-lg bg-[#a35fc1]/10 text-[#a35fc1] font-bold\" data-kid=\"88\">1</button>\n          <button class=\"glass-card flex h-8 w-8 items-center justify-center rounded-lg text-neutral-500 hover:bg-white/50 transition-all font-bold\" data-kid=\"89\">2</button>\n          <button class=\"glass-card flex h-8 w-8 items-center justify-center rounded-lg text-neutral-400 hover:text-[#a35fc1] transition-all\" data-kid=\"90\"><i class=\"ti ti-chevron-right\" data-kid=\"91\"></i></button>\n        </div>\n      </div>\n    </section>\n\n    \n    <section class=\"mt-12\" data-kid=\"92\">\n       <div class=\"grid grid-cols-1 md:grid-cols-3 gap-6\" data-kid=\"93\">\n          <div class=\"glass-card rounded-3xl p-6 flex items-center gap-5\" data-kid=\"94\">\n             <div class=\"flex h-14 w-14 items-center justify-center rounded-2xl bg-emerald-100 text-emerald-600 shadow-inner\" data-kid=\"95\">\n                <i class=\"ti ti-check text-2xl\" data-kid=\"96\"></i>\n             </div>\n             <div data-kid=\"97\">\n                <p class=\"text-sm font-bold text-neutral-400 uppercase tracking-tighter\" data-kid=\"98\">Aprobado Venta</p>\n                <h3 class=\"text-3xl font-bold text-neutral-800 tracking-tighter\" data-kid=\"99\">84<span class=\"text-lg text-neutral-400 ml-1\" data-kid=\"100\">und</span></h3>\n             </div>\n          </div>\n          <div class=\"glass-card rounded-3xl p-6 flex items-center gap-5\" data-kid=\"101\">\n             <div class=\"flex h-14 w-14 items-center justify-center rounded-2xl bg-blue-100 text-blue-600 shadow-inner\" data-kid=\"102\">\n                <i class=\"ti ti-flask text-2xl\" data-kid=\"103\"></i>\n             </div>\n             <div data-kid=\"104\">\n                <p class=\"text-sm font-bold text-neutral-400 uppercase tracking-tighter\" data-kid=\"105\">En Análisis</p>\n                <h3 class=\"text-3xl font-bold text-neutral-800 tracking-tighter\" data-kid=\"106\">21<span class=\"text-lg text-neutral-400 ml-1\" data-kid=\"107\">und</span></h3>\n             </div>\n          </div>\n          <div class=\"glass-card rounded-3xl p-6 flex items-center gap-5\" data-kid=\"108\">\n             <div class=\"flex h-14 w-14 items-center justify-center rounded-2xl bg-rose-100 text-rose-600 shadow-inner\" data-kid=\"109\">\n                <i class=\"ti ti-arrow-back-up text-2xl\" data-kid=\"110\"></i>\n             </div>\n             <div data-kid=\"111\">\n                <p class=\"text-sm font-bold text-neutral-400 uppercase tracking-tighter\" data-kid=\"112\">Dev. Proveedor</p>\n                <h3 class=\"text-3xl font-bold text-neutral-800 tracking-tighter\" data-kid=\"113\">09<span class=\"text-lg text-neutral-400 ml-1\" data-kid=\"114\">und</span></h3>\n             </div>\n          </div>\n       </div>\n    </section>\n  </main>\n</div>",
