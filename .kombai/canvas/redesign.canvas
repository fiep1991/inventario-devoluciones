      "html": "<style data-kid=\"0\">\n  @import url('https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;700&family=IBM+Plex+Mono:wght@500;700&display=swap');\n\n  body {\n    background-color: #ffffff;\n    font-family: 'Space Grotesk', sans-serif;\n    color: #565656;\n    margin: 0;\n    padding: 0;\n  }\n\n  .font-mono {\n    font-family: 'IBM Plex Mono', monospace;\n  }\n\n  .neo-border {\n    border: 2px solid #565656;\n  }\n\n  .neo-shadow {\n    box-shadow: 4px 4px 0px 0px #565656;\n  }\n\n  .neo-shadow-sm {\n    box-shadow: 2px 2px 0px 0px #565656;\n  }\n\n  .neo-shadow-hover:hover {\n    transform: translate(-2px, -2px);\n    box-shadow: 6px 6px 0px 0px #565656;\n  }\n\n  .neo-shadow-active:active {\n    transform: translate(2px, 2px);\n    box-shadow: 0px 0px 0px 0px #565656;\n  }\n</style>\n\n<div class=\"min-h-screen bg-white\" data-kid=\"1\">\n  \n  <nav class=\"neo-border bg-[#9c9aee] px-8 py-4 flex justify-between items-center sticky top-0 z-50\" data-kid=\"2\">\n    <div class=\"flex items-center gap-4\" data-kid=\"3\">\n      <div class=\"neo-border bg-white p-2 neo-shadow-sm\" data-kid=\"4\">\n        <i class=\"ti ti-box text-2xl\" data-kid=\"5\"></i>\n      </div>\n      <span class=\"text-2xl font-bold tracking-tight uppercase\" data-kid=\"6\">Inventario Pro</span>\n    </div>\n    <div class=\"flex gap-6 font-bold uppercase text-sm\" data-kid=\"7\">\n      <a href=\"#\" class=\"hover:underline\" data-kid=\"8\">Inicio</a>\n      <a href=\"#\" class=\"neo-border bg-white px-4 py-1 neo-shadow-sm\" data-kid=\"9\">Seguimiento</a>\n      <a href=\"#\" class=\"hover:underline\" data-kid=\"10\">Reportes</a>\n    </div>\n  </nav>\n\n  <main class=\"max-w-6xl mx-auto p-8\" data-kid=\"11\">\n    \n    <header class=\"mb-12 flex flex-col md:flex-row md:items-end justify-between gap-6\" data-kid=\"12\">\n      <div data-kid=\"13\">\n        <h1 class=\"text-5xl font-bold uppercase mb-2\" data-kid=\"14\">Seguimiento de Devoluciones</h1>\n        <p class=\"text-xl font-medium\" data-kid=\"15\">Gestión y control de calidad en tiempo real.</p>\n      </div>\n      <div class=\"flex gap-4\" data-kid=\"16\">\n        <button class=\"neo-border bg-[#f27405] text-white px-6 py-3 font-bold uppercase neo-shadow-sm neo-shadow-active\" data-kid=\"17\">\n          <i class=\"ti ti-filter mr-2\" data-kid=\"18\"></i> Filtrar\n        </button>\n        <button class=\"neo-border bg-white px-6 py-3 font-bold uppercase neo-shadow-sm neo-shadow-active\" data-kid=\"19\">\n          <i class=\"ti ti-search mr-2\" data-kid=\"20\"></i> Buscar\n        </button>\n      </div>\n    </header>\n\n    \n    <div class=\"flex gap-2 mb-8\" data-kid=\"21\">\n      <button class=\"neo-border bg-[#9c9aee] px-6 py-2 font-bold uppercase neo-shadow-sm\" data-kid=\"22\">Coordinador (4)</button>\n      <button class=\"neo-border bg-white px-6 py-2 font-bold uppercase hover:bg-gray-50\" data-kid=\"23\">Calidad (2)</button>\n    </div>\n\n    \n    <div class=\"grid grid-cols-1 gap-6\" data-kid=\"24\">\n      \n      <div class=\"neo-border p-6 neo-shadow bg-white neo-shadow-hover transition-all\" data-kid=\"25\">\n        <div class=\"flex flex-wrap items-start justify-between gap-4 mb-6\" data-kid=\"26\">\n          <div class=\"flex items-center gap-4\" data-kid=\"27\">\n            <div class=\"neo-border bg-[#f27405]/10 p-3\" data-kid=\"28\">\n              <i class=\"ti ti-truck-return text-2xl text-[#f27405]\" data-kid=\"29\"></i>\n            </div>\n            <div data-kid=\"30\">\n              <div class=\"text-xs font-bold uppercase text-gray-400 mb-1\" data-kid=\"31\">ID Devolución</div>\n              <div class=\"font-mono text-xl font-bold\" data-kid=\"32\">#DEV-2024-001</div>\n            </div>\n          </div>\n          <div class=\"flex gap-2\" data-kid=\"33\">\n            <span class=\"neo-border bg-[#9c9aee]/20 px-3 py-1 text-xs font-bold uppercase\" data-kid=\"34\">En Recepción</span>\n            <span class=\"neo-border bg-gray-100 px-3 py-1 text-xs font-bold uppercase\" data-kid=\"35\">20/06/2026</span>\n          </div>\n        </div>\n\n        <div class=\"grid grid-cols-1 md:grid-cols-4 gap-6 mb-6\" data-kid=\"36\">\n          <div data-kid=\"37\">\n            <div class=\"text-xs font-bold uppercase text-gray-400 mb-1\" data-kid=\"38\">Cliente</div>\n            <div class=\"font-bold\" data-kid=\"39\">Distribuidora Central S.A.</div>\n          </div>\n          <div data-kid=\"40\">\n            <div class=\"text-xs font-bold uppercase text-gray-400 mb-1\" data-kid=\"41\">Producto</div>\n            <div class=\"font-bold\" data-kid=\"42\">Monitor UltraWide 34\"</div>\n          </div>\n          <div data-kid=\"43\">\n            <div class=\"text-xs font-bold uppercase text-gray-400 mb-1\" data-kid=\"44\">Código / Lote</div>\n            <div class=\"font-mono font-bold\" data-kid=\"45\">M34-UW / <span class=\"text-[#f27405]\" data-kid=\"46\">L-99283</span></div>\n          </div>\n          <div data-kid=\"47\">\n            <div class=\"text-xs font-bold uppercase text-gray-400 mb-1\" data-kid=\"48\">Cantidad</div>\n            <div class=\"font-bold\" data-kid=\"49\">12 Unidades</div>\n          </div>\n        </div>\n\n        <div class=\"neo-border bg-gray-50 p-4 mb-6\" data-kid=\"50\">\n          <div class=\"text-xs font-bold uppercase text-gray-400 mb-2\" data-kid=\"51\">Observaciones</div>\n          <p class=\"text-sm\" data-kid=\"52\">Empaque primario dañado durante el transporte. Se requiere revisión de sellos internos.</p>\n        </div>\n\n        <div class=\"flex justify-end gap-4\" data-kid=\"53\">\n          <button class=\"neo-border px-4 py-2 font-bold uppercase hover:bg-gray-50 neo-shadow-active\" data-kid=\"54\">Editar Detalles</button>\n          <button class=\"neo-border bg-[#a35fc1] text-white px-6 py-2 font-bold uppercase neo-shadow-sm neo-shadow-active\" data-kid=\"55\">Verificar</button>\n        </div>\n      </div>\n\n      \n      <div class=\"neo-border p-6 neo-shadow bg-white border-l-[12px] border-l-[#a35fc1] neo-shadow-hover transition-all\" data-kid=\"56\">\n        <div class=\"flex flex-wrap items-start justify-between gap-4 mb-6\" data-kid=\"57\">\n          <div class=\"flex items-center gap-4\" data-kid=\"58\">\n            <div class=\"neo-border bg-[#a35fc1]/10 p-3\" data-kid=\"59\">\n              <i class=\"ti ti-clipboard-check text-2xl text-[#a35fc1]\" data-kid=\"60\"></i>\n            </div>\n            <div data-kid=\"61\">\n              <div class=\"text-xs font-bold uppercase text-gray-400 mb-1\" data-kid=\"62\">ID Devolución</div>\n              <div class=\"font-mono text-xl font-bold\" data-kid=\"63\">#DEV-2024-042</div>\n            </div>\n          </div>\n          <div class=\"flex gap-2\" data-kid=\"64\">\n            <span class=\"neo-border bg-[#a35fc1] text-white px-3 py-1 text-xs font-bold uppercase\" data-kid=\"65\">Verificado</span>\n            <span class=\"neo-border bg-gray-100 px-3 py-1 text-xs font-bold uppercase\" data-kid=\"66\">19/06/2026</span>\n          </div>\n        </div>\n\n        <div class=\"grid grid-cols-1 md:grid-cols-4 gap-6 mb-6\" data-kid=\"67\">\n          <div data-kid=\"68\">\n            <div class=\"text-xs font-bold uppercase text-gray-400 mb-1\" data-kid=\"69\">Cliente</div>\n            <div class=\"font-bold\" data-kid=\"70\">Logística Global Express</div>\n          </div>\n          <div data-kid=\"71\">\n            <div class=\"text-xs font-bold uppercase text-gray-400 mb-1\" data-kid=\"72\">Producto</div>\n            <div class=\"font-bold\" data-kid=\"73\">Teclado Mecánico RGB</div>\n          </div>\n          <div data-kid=\"74\">\n            <div class=\"text-xs font-bold uppercase text-gray-400 mb-1\" data-kid=\"75\">Código / Lote</div>\n            <div class=\"font-mono font-bold\" data-kid=\"76\">KB-MEC-01 / <span class=\"text-[#f27405]\" data-kid=\"77\">L-88122</span></div>\n          </div>\n          <div data-kid=\"78\">\n            <div class=\"text-xs font-bold uppercase text-gray-400 mb-1\" data-kid=\"79\">Estado Físico</div>\n            <div class=\"font-bold text-red-500 italic\" data-kid=\"80\">Caja abierta</div>\n          </div>\n        </div>\n\n        <div class=\"flex flex-col md:flex-row items-center justify-between gap-6 p-4 neo-border bg-[#f2f2f2]\" data-kid=\"81\">\n          <div class=\"w-full md:w-auto\" data-kid=\"82\">\n            <label class=\"block text-xs font-bold uppercase text-gray-400 mb-2\" data-kid=\"83\">Disposición de Calidad</label>\n            <select class=\"neo-border bg-white px-4 py-2 font-bold w-full md:w-64 focus:bg-[#9c9aee]/10 outline-none\" data-kid=\"84\">\n              <option data-kid=\"85\">Seleccionar acción...</option>\n              <option data-kid=\"86\">Aprobar para venta</option>\n              <option data-kid=\"87\">Enviar a análisis</option>\n              <option data-kid=\"88\">Enviar a planta</option>\n              <option data-kid=\"89\">Devolver a proveedor</option>\n            </select>\n          </div>\n          <button class=\"neo-border bg-[#f27405] text-white px-8 py-2 font-bold uppercase neo-shadow-sm neo-shadow-active w-full md:w-auto\" data-kid=\"90\">\n            Finalizar Proceso\n          </button>\n        </div>\n      </div>\n    </div>\n  </main>\n</div>\n\n\n<link rel=\"stylesheet\" href=\"https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css\" data-kid=\"91\">",
