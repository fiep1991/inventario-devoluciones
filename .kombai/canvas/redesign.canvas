      "html": "<style data-kid=\"0\">\n  @import url('https://fonts.googleapis.com/css2?family=Poppins:wght@400;600;700&family=Nunito:wght@400;600&display=swap');\n  @import url('https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css');\n\n  body {\n    font-family: 'Nunito', sans-serif;\n    margin: 0;\n    padding: 0;\n  }\n\n  .font-poppins {\n    font-family: 'Poppins', sans-serif;\n  }\n\n  .glass {\n    background: rgba(255, 255, 255, 0.2);\n    backdrop-filter: blur(20px);\n    -webkit-backdrop-filter: blur(20px);\n    border: 1px solid rgba(255, 255, 255, 0.3);\n  }\n\n  .glass-card {\n    background: rgba(255, 255, 255, 0.6);\n    backdrop-filter: blur(15px);\n    -webkit-backdrop-filter: blur(15px);\n    border: 1px solid rgba(255, 255, 255, 0.4);\n    box-shadow: 0 8px 32px 0 rgba(31, 38, 135, 0.1);\n  }\n\n  .glass-input {\n    background: rgba(255, 255, 255, 0.5);\n    border: 1px solid rgba(255, 255, 255, 0.5);\n    transition: all 0.3s ease;\n  }\n\n  .glass-input:focus {\n    background: rgba(255, 255, 255, 0.8);\n    border-color: #a35fc1;\n    box-shadow: 0 0 0 4px rgba(163, 95, 193, 0.1);\n    outline: none;\n  }\n\n  .bg-mesh {\n    background-color: #f2f2f2;\n    background-image: \n      radial-gradient(at 0% 0%, rgba(156, 154, 238, 0.15) 0px, transparent 50%),\n      radial-gradient(at 100% 0%, rgba(242, 116, 5, 0.1) 0px, transparent 50%),\n      radial-gradient(at 100% 100%, rgba(163, 95, 193, 0.15) 0px, transparent 50%),\n      radial-gradient(at 0% 100%, rgba(156, 154, 238, 0.1) 0px, transparent 50%);\n  }\n\n  .blob {\n    position: absolute;\n    width: 500px;\n    height: 500px;\n    background: #9c9aee;\n    filter: blur(80px);\n    opacity: 0.2;\n    z-index: -1;\n    border-radius: 50%;\n  }\n</style>\n\n<div class=\"min-h-screen bg-mesh relative overflow-hidden flex flex-col\" data-kid=\"1\">\n  \n  <div class=\"blob top-[-10%] left-[-10%]\" style=\"background: #9c9aee;\" data-kid=\"2\"></div>\n  <div class=\"blob bottom-[-10%] right-[-10%]\" style=\"background: #f27405;\" data-kid=\"3\"></div>\n\n  \n  <header class=\"p-6\" data-kid=\"4\">\n    <nav class=\"max-w-4xl mx-auto glass rounded-full px-8 py-4 flex items-center justify-between shadow-sm\" data-kid=\"5\">\n      <div class=\"flex items-center gap-2\" data-kid=\"6\">\n        <div class=\"w-10 h-10 bg-gradient-to-br from-[#a35fc1] to-[#9c9aee] rounded-xl flex items-center justify-center text-white\" data-kid=\"7\">\n          <i class=\"ti ti-box text-2xl\" data-kid=\"8\"></i>\n        </div>\n        <span class=\"font-poppins font-bold text-xl text-neutral-800\" data-kid=\"9\">Inventario</span>\n      </div>\n      <div class=\"hidden md:flex items-center gap-8\" data-kid=\"10\">\n        <a href=\"#\" class=\"text-sm font-semibold text-neutral-600 hover:text-[#a35fc1] transition-colors\" data-kid=\"11\">Inicio</a>\n        <a href=\"#\" class=\"text-sm font-semibold text-[#a35fc1] transition-colors relative\" data-kid=\"12\">\n          Recepción\n          <span class=\"absolute -bottom-1 left-1/2 -translate-x-1/2 w-1 h-1 bg-[#a35fc1] rounded-full\" data-kid=\"13\"></span>\n        </a>\n        <a href=\"#\" class=\"text-sm font-semibold text-neutral-600 hover:text-[#a35fc1] transition-colors\" data-kid=\"14\">Coordinador</a>\n        <a href=\"#\" class=\"text-sm font-semibold text-neutral-600 hover:text-[#a35fc1] transition-colors\" data-kid=\"15\">Calidad</a>\n      </div>\n      <div class=\"flex items-center gap-4\" data-kid=\"16\">\n        <button class=\"w-10 h-10 rounded-full flex items-center justify-center text-neutral-500 hover:bg-white/40 transition-colors\" data-kid=\"17\">\n          <i class=\"ti ti-bell text-xl\" data-kid=\"18\"></i>\n        </button>\n        <div class=\"w-10 h-10 rounded-full bg-white border border-white/50 overflow-hidden\" data-kid=\"19\">\n          <img src=\"https://i.pravatar.cc/100?u=felipe\" alt=\"User\" class=\"w-full h-full object-cover\" data-kid=\"20\">\n        </div>\n      </div>\n    </nav>\n  </header>\n\n  \n  <main class=\"flex-1 flex flex-col items-center justify-center p-6 pb-20\" data-kid=\"21\">\n    <div class=\"w-full max-w-2xl\" data-kid=\"22\">\n      \n      <div class=\"text-center mb-8\" data-kid=\"23\">\n        <h1 class=\"font-poppins text-4xl font-bold text-neutral-800 mb-2\" data-kid=\"24\">Nueva Devolución</h1>\n        <p class=\"text-neutral-500 font-medium\" data-kid=\"25\">Completa los datos para registrar el ingreso a bodega</p>\n      </div>\n\n      \n      <div class=\"glass-card rounded-[32px] overflow-hidden shadow-2xl\" data-kid=\"26\">\n        \n        <div class=\"bg-white/40 border-b border-white/30 p-8\" data-kid=\"27\">\n          <div class=\"flex items-center justify-between mb-4\" data-kid=\"28\">\n            <span class=\"text-sm font-bold text-[#a35fc1] uppercase tracking-wider\" data-kid=\"29\">Paso 1 de 3</span>\n            <span class=\"text-sm font-bold text-neutral-400 uppercase tracking-wider\" data-kid=\"30\">Datos del Cliente</span>\n          </div>\n          <div class=\"h-2 w-full bg-white/50 rounded-full overflow-hidden\" data-kid=\"31\">\n            <div class=\"h-full bg-gradient-to-r from-[#a35fc1] to-[#9c9aee] w-1/3 rounded-full shadow-[0_0_10px_rgba(163,95,193,0.3)]\" data-kid=\"32\"></div>\n          </div>\n        </div>\n\n        \n        <div class=\"p-8 md:p-12\" data-kid=\"33\">\n          <form class=\"space-y-8\" data-kid=\"34\">\n            <div class=\"grid grid-cols-1 md:grid-cols-2 gap-6\" data-kid=\"35\">\n              \n              <div class=\"space-y-2\" data-kid=\"36\">\n                <label class=\"block text-sm font-bold text-neutral-600 ml-1\" data-kid=\"37\">Fecha de Ingreso</label>\n                <div class=\"relative\" data-kid=\"38\">\n                  <span class=\"absolute left-4 top-1/2 -translate-y-1/2 text-neutral-400\" data-kid=\"39\">\n                    <i class=\"ti ti-calendar text-xl\" data-kid=\"40\"></i>\n                  </span>\n                  <input type=\"date\" class=\"w-full glass-input rounded-2xl py-4 pl-12 pr-4 text-neutral-700 font-medium\" value=\"2026-06-20\" data-kid=\"41\">\n                </div>\n              </div>\n\n              \n              <div class=\"space-y-2\" data-kid=\"42\">\n                <label class=\"block text-sm font-bold text-neutral-600 ml-1\" data-kid=\"43\">Cliente</label>\n                <div class=\"relative\" data-kid=\"44\">\n                  <span class=\"absolute left-4 top-1/2 -translate-y-1/2 text-neutral-400\" data-kid=\"45\">\n                    <i class=\"ti ti-user text-xl\" data-kid=\"46\"></i>\n                  </span>\n                  <input type=\"text\" placeholder=\"Nombre del cliente...\" class=\"w-full glass-input rounded-2xl py-4 pl-12 pr-4 text-neutral-700 font-medium\" data-kid=\"47\">\n                </div>\n              </div>\n\n              \n              <div class=\"md:col-span-2 space-y-2\" data-kid=\"48\">\n                <label class=\"block text-sm font-bold text-neutral-600 ml-1\" data-kid=\"49\">Producto</label>\n                <div class=\"relative\" data-kid=\"50\">\n                  <span class=\"absolute left-4 top-1/2 -translate-y-1/2 text-neutral-400\" data-kid=\"51\">\n                    <i class=\"ti ti-package text-xl\" data-kid=\"52\"></i>\n                  </span>\n                  <input type=\"text\" placeholder=\"Busca o ingresa el producto...\" class=\"w-full glass-input rounded-2xl py-4 pl-12 pr-4 text-neutral-700 font-medium\" data-kid=\"53\">\n                </div>\n              </div>\n            </div>\n\n            \n            <div class=\"bg-white/20 rounded-2xl p-6 border border-white/30 flex items-start gap-4\" data-kid=\"54\">\n              <div class=\"w-10 h-10 rounded-full bg-[#9c9aee]/20 flex-shrink-0 flex items-center justify-center text-[#9c9aee]\" data-kid=\"55\">\n                <i class=\"ti ti-info-circle text-2xl\" data-kid=\"56\"></i>\n              </div>\n              <div data-kid=\"57\">\n                <h4 class=\"font-bold text-neutral-700 text-sm\" data-kid=\"58\">Información importante</h4>\n                <p class=\"text-xs text-neutral-500 leading-relaxed mt-1\" data-kid=\"59\">Asegúrate de que la fecha coincida con la recepción física del material para evitar discrepancias en inventario.</p>\n              </div>\n            </div>\n\n            \n            <div class=\"pt-6 flex items-center justify-end gap-4\" data-kid=\"60\">\n              <button type=\"button\" class=\"px-8 py-4 rounded-full font-bold text-neutral-500 hover:bg-white/40 transition-all\" data-kid=\"61\">\n                Cancelar\n              </button>\n              <button type=\"button\" class=\"px-12 py-4 rounded-full bg-gradient-to-r from-[#a35fc1] to-[#9c9aee] text-white font-bold shadow-lg shadow-[#a35fc1]/20 hover:scale-[1.02] active:scale-[0.98] transition-all flex items-center gap-2\" data-kid=\"62\">\n                Siguiente Paso\n                <i class=\"ti ti-arrow-right\" data-kid=\"63\"></i>\n              </button>\n            </div>\n          </form>\n        </div>\n      </div>\n\n      \n      <div class=\"mt-12 flex justify-center opacity-30\" data-kid=\"64\">\n        <video src=\"https://videos.pexels.com/video-files/11738195/11738195-hd_1280_720_24fps.mp4\" poster=\"https://images.pexels.com/videos/11738195/pexels-photo-11738195.jpeg?auto=compress&cs=tinysrgb&fit=crop&h=630&w=1200\" autoplay muted loop playsinline preload=\"metadata\" class=\"w-32 h-32 rounded-full object-cover grayscale\" data-kid=\"65\"></video>\n      </div>\n    </div>\n  </main>\n</div>",
