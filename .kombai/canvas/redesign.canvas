    "var_56103395b258": {
      "type": "variant",
      "label": "Recepción - Glassmorphic",
      "parentId": "var_4c23191bb253",
      "themeId": null,
      "rect": {
        "x": 9660,
        "y": 0,
        "w": 1280,
        "h": 800
