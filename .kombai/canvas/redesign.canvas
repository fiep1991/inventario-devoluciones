      "html": "<style data-kid=\"0\">\n  @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap');\n  @import url('https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css');\n\n  body {\n    font-family: 'Inter', sans-serif;\n    margin: 0;\n    padding: 0;\n    background-color: #f2f2f2;\n    color: #565656;\n  }\n\n  .enterprise-shadow {\n    box-shadow: 0 1px 3px 0 rgba(0, 0, 0, 0.1), 0 1px 2px 0 rgba(0, 0, 0, 0.06);\n  }\n</style>\n\n<div class=\"min-h-screen flex flex-col\" data-kid=\"1\">\n  \n  <nav class=\"bg-white border-b border-neutral-200 sticky top-0 z-50\" data-kid=\"2\">\n    <div class=\"max-w-7xl mx-auto px-4 sm:px-6 lg:px-8\" data-kid=\"3\">\n      <div class=\"flex justify-between h-16\" data-kid=\"4\">\n        <div class=\"flex items-center gap-8\" data-kid=\"5\">\n          <div class=\"flex-shrink-0 flex items-center gap-2\" data-kid=\"6\">\n            <div class=\"w-8 h-8 bg-[#a35fc1] rounded flex items-center justify-center\" data-kid=\"7\">\n              <i class=\"ti ti-package text-white text-xl\" data-kid=\"8\"></i>\n            </div>\n            <span class=\"text-xl font-bold text-neutral-800 tracking-tight\" data-kid=\"9\">LOGIS<span class=\"text-[#a35fc1]\" data-kid=\"10\">TECH</span></span>\n          </div>\n          <div class=\"hidden sm:flex sm:space-x-8 h-full\" data-kid=\"11\">\n            <a href=\"#\" class=\"border-transparent text-neutral-500 hover:text-neutral-700 inline-flex items-center px-1 pt-1 border-b-2 text-sm font-medium\" data-kid=\"12\">Dashboard</a>\n            <a href=\"#\" class=\"border-transparent text-neutral-500 hover:text-neutral-700 inline-flex items-center px-1 pt-1 border-b-2 text-sm font-medium\" data-kid=\"13\">Recepción</a>\n            <a href=\"#\" class=\"border-[#a35fc1] text-neutral-900 inline-flex items-center px-1 pt-1 border-b-2 text-sm font-medium\" data-kid=\"14\">Seguimiento</a>\n            <a href=\"#\" class=\"border-transparent text-neutral-500 hover:text-neutral-700 inline-flex items-center px-1 pt-1 border-b-2 text-sm font-medium\" data-kid=\"15\">Reportes</a>\n          </div>\n        </div>\n        <div class=\"flex items-center gap-4\" data-kid=\"16\">\n          <button class=\"p-2 text-neutral-400 hover:text-neutral-600\" data-kid=\"17\">\n            <i class=\"ti ti-bell text-xl\" data-kid=\"18\"></i>\n          </button>\n          <div class=\"flex items-center gap-2 pl-4 border-l border-neutral-200\" data-kid=\"19\">\n            <img src=\"https://i.pravatar.cc/32?u=felipe\" alt=\"Profile\" class=\"w-8 h-8 rounded-full border border-neutral-200\" data-kid=\"20\">\n            <div class=\"hidden md:block text-left\" data-kid=\"21\">\n              <p class=\"text-xs font-semibold text-neutral-800 leading-none\" data-kid=\"22\">Felipe G.</p>\n              <p class=\"text-[10px] text-neutral-500 mt-1\" data-kid=\"23\">Coordinador</p>\n            </div>\n          </div>\n        </div>\n      </div>\n    </div>\n  </nav>\n\n  <main class=\"flex-1 max-w-7xl w-full mx-auto py-8 px-4 sm:px-6 lg:px-8\" data-kid=\"24\">\n    \n    <div class=\"flex flex-col md:flex-row md:items-end justify-between gap-6 mb-8\" data-kid=\"25\">\n      <div data-kid=\"26\">\n        <h1 class=\"text-2xl font-bold text-neutral-900\" data-kid=\"27\">Centro de Seguimiento de Devoluciones</h1>\n        <p class=\"text-neutral-500 mt-1\" data-kid=\"28\">Gestione y procese las devoluciones pendientes en las etapas de Coordinación y Calidad.</p>\n      </div>\n      <div class=\"flex gap-4\" data-kid=\"29\">\n        <div class=\"bg-white p-4 rounded-lg enterprise-shadow border border-neutral-200 flex items-center gap-4\" data-kid=\"30\">\n          <div class=\"w-10 h-10 rounded-full bg-amber-50 flex items-center justify-center text-amber-600\" data-kid=\"31\">\n            <i class=\"ti ti-clock-pause text-xl\" data-kid=\"32\"></i>\n          </div>\n          <div data-kid=\"33\">\n            <p class=\"text-xs text-neutral-500 font-medium uppercase tracking-wider\" data-kid=\"34\">Pendientes Coord.</p>\n            <p class=\"text-xl font-bold text-neutral-900\" data-kid=\"35\">12</p>\n          </div>\n        </div>\n        <div class=\"bg-white p-4 rounded-lg enterprise-shadow border border-neutral-200 flex items-center gap-4\" data-kid=\"36\">\n          <div class=\"w-10 h-10 rounded-full bg-blue-50 flex items-center justify-center text-blue-600\" data-kid=\"37\">\n            <i class=\"ti ti-microscope text-xl\" data-kid=\"38\"></i>\n          </div>\n          <div data-kid=\"39\">\n            <p class=\"text-xs text-neutral-500 font-medium uppercase tracking-wider\" data-kid=\"40\">En Calidad</p>\n            <p class=\"text-xl font-bold text-neutral-900\" data-kid=\"41\">08</p>\n          </div>\n        </div>\n      </div>\n    </div>\n\n    \n    <div class=\"bg-white rounded-xl enterprise-shadow border border-neutral-200 overflow-hidden\" data-kid=\"42\">\n      \n      <div class=\"border-b border-neutral-200 bg-neutral-50/50\" data-kid=\"43\">\n        <div class=\"flex flex-col md:flex-row md:items-center justify-between px-6 py-4 gap-4\" data-kid=\"44\">\n          <div class=\"flex gap-1 bg-neutral-200/50 p-1 rounded-lg\" data-kid=\"45\">\n            <button class=\"px-4 py-1.5 text-sm font-semibold rounded-md bg-white text-neutral-900 enterprise-shadow\" data-kid=\"46\">\n              Coordinación\n            </button>\n            <button class=\"px-4 py-1.5 text-sm font-medium rounded-md text-neutral-500 hover:text-neutral-700\" data-kid=\"47\">\n              Calidad\n            </button>\n          </div>\n          <div class=\"flex gap-3 items-center\" data-kid=\"48\">\n            <div class=\"relative\" data-kid=\"49\">\n              <i class=\"ti ti-search absolute left-3 top-1/2 -translate-y-1/2 text-neutral-400\" data-kid=\"50\"></i>\n              <input type=\"text\" placeholder=\"Buscar por Lote, Cliente o ID...\" class=\"pl-10 pr-4 py-2 bg-white border border-neutral-300 rounded-lg text-sm focus:ring-2 focus:ring-[#a35fc1]/20 focus:border-[#a35fc1] outline-none w-full md:w-64 transition-all\" data-kid=\"51\">\n            </div>\n            <button class=\"flex items-center gap-2 px-3 py-2 border border-neutral-300 rounded-lg text-sm font-medium text-neutral-600 bg-white hover:bg-neutral-50\" data-kid=\"52\">\n              <i class=\"ti ti-filter\" data-kid=\"53\"></i>\n              Filtros\n            </button>\n            <button class=\"flex items-center gap-2 px-3 py-2 bg-[#a35fc1] text-white rounded-lg text-sm font-semibold hover:bg-[#8e4da8] transition-colors\" data-kid=\"54\">\n              <i class=\"ti ti-download\" data-kid=\"55\"></i>\n              Exportar\n            </button>\n          </div>\n        </div>\n      </div>\n\n      \n      <div class=\"overflow-x-auto\" data-kid=\"56\">\n        <table class=\"w-full text-left border-collapse\" data-kid=\"57\">\n          <thead data-kid=\"58\">\n            <tr class=\"bg-neutral-50 border-b border-neutral-200\" data-kid=\"59\">\n              <th class=\"px-6 py-4 text-xs font-bold text-neutral-500 uppercase tracking-wider\" data-kid=\"60\">Lote / Fecha</th>\n              <th class=\"px-6 py-4 text-xs font-bold text-neutral-500 uppercase tracking-wider\" data-kid=\"61\">Cliente</th>\n              <th class=\"px-6 py-4 text-xs font-bold text-neutral-500 uppercase tracking-wider\" data-kid=\"62\">Producto / Código</th>\n              <th class=\"px-6 py-4 text-xs font-bold text-neutral-500 uppercase tracking-wider\" data-kid=\"63\">Cantidad</th>\n              <th class=\"px-6 py-4 text-xs font-bold text-neutral-500 uppercase tracking-wider\" data-kid=\"64\">Estado</th>\n              <th class=\"px-6 py-4 text-xs font-bold text-neutral-500 uppercase tracking-wider text-right\" data-kid=\"65\">Acciones</th>\n            </tr>\n          </thead>\n          <tbody class=\"divide-y divide-neutral-200\" data-kid=\"66\">\n            <tr class=\"hover:bg-neutral-50 transition-colors group\" data-kid=\"67\">\n              <td class=\"px-6 py-4\" data-kid=\"68\">\n                <p class=\"text-sm font-semibold text-neutral-900\" data-kid=\"69\">#LT-8842</p>\n                <p class=\"text-[11px] text-neutral-400 mt-0.5\" data-kid=\"70\">20 Jun 2026, 09:15 AM</p>\n              </td>\n              <td class=\"px-6 py-4\" data-kid=\"71\">\n                <p class=\"text-sm font-medium text-neutral-700\" data-kid=\"72\">Distribuidora Central S.A.</p>\n              </td>\n              <td class=\"px-6 py-4\" data-kid=\"73\">\n                <p class=\"text-sm font-medium text-neutral-700\" data-kid=\"74\">Monitor UltraWide 34\"</p>\n                <p class=\"text-[11px] font-mono text-neutral-400 mt-0.5\" data-kid=\"75\">SKU: MON-34-UW-01</p>\n              </td>\n              <td class=\"px-6 py-4\" data-kid=\"76\">\n                <span class=\"text-sm font-bold text-neutral-800\" data-kid=\"77\">15</span>\n                <span class=\"text-[10px] text-neutral-400 ml-1\" data-kid=\"78\">unid.</span>\n              </td>\n              <td class=\"px-6 py-4\" data-kid=\"79\">\n                <span class=\"inline-flex items-center gap-1.5 px-2.5 py-0.5 rounded-full text-xs font-bold bg-amber-100 text-amber-700\" data-kid=\"80\">\n                  <span class=\"w-1.5 h-1.5 rounded-full bg-amber-500\" data-kid=\"81\"></span>\n                  En Coordinación\n                </span>\n              </td>\n              <td class=\"px-6 py-4 text-right\" data-kid=\"82\">\n                <button class=\"p-2 text-neutral-400 hover:text-[#a35fc1] hover:bg-[#a35fc1]/5 rounded-lg transition-all\" data-kid=\"83\">\n                  <i class=\"ti ti-edit text-lg\" data-kid=\"84\"></i>\n                </button>\n              </td>\n            </tr>\n            <tr class=\"bg-neutral-50/50 hover:bg-neutral-50 transition-colors group\" data-kid=\"85\">\n              <td class=\"px-6 py-4\" data-kid=\"86\">\n                <p class=\"text-sm font-semibold text-neutral-900\" data-kid=\"87\">#LT-8841</p>\n                <p class=\"text-[11px] text-neutral-400 mt-0.5\" data-kid=\"88\">20 Jun 2026, 08:30 AM</p>\n              </td>\n              <td class=\"px-6 py-4\" data-kid=\"89\">\n                <p class=\"text-sm font-medium text-neutral-700\" data-kid=\"90\">Retail Solutions LTDA</p>\n              </td>\n              <td class=\"px-6 py-4\" data-kid=\"91\">\n                <p class=\"text-sm font-medium text-neutral-700\" data-kid=\"92\">Teclado Mecánico RGB</p>\n                <p class=\"text-[11px] font-mono text-neutral-400 mt-0.5\" data-kid=\"93\">SKU: KBD-RGB-MEC</p>\n              </td>\n              <td class=\"px-6 py-4\" data-kid=\"94\">\n                <span class=\"text-sm font-bold text-neutral-800\" data-kid=\"95\">42</span>\n                <span class=\"text-[10px] text-neutral-400 ml-1\" data-kid=\"96\">unid.</span>\n              </td>\n              <td class=\"px-6 py-4\" data-kid=\"97\">\n                <span class=\"inline-flex items-center gap-1.5 px-2.5 py-0.5 rounded-full text-xs font-bold bg-blue-100 text-blue-700\" data-kid=\"98\">\n                  <span class=\"w-1.5 h-1.5 rounded-full bg-blue-500\" data-kid=\"99\"></span>\n                  En Calidad\n                </span>\n              </td>\n              <td class=\"px-6 py-4 text-right\" data-kid=\"100\">\n                <button class=\"p-2 text-neutral-400 hover:text-[#a35fc1] hover:bg-[#a35fc1]/5 rounded-lg transition-all\" data-kid=\"101\">\n                  <i class=\"ti ti-external-link text-lg\" data-kid=\"102\"></i>\n                </button>\n              </td>\n            </tr>\n            <tr class=\"hover:bg-neutral-50 transition-colors group\" data-kid=\"103\">\n              <td class=\"px-6 py-4\" data-kid=\"104\">\n                <p class=\"text-sm font-semibold text-neutral-900\" data-kid=\"105\">#LT-8839</p>\n                <p class=\"text-[11px] text-neutral-400 mt-0.5\" data-kid=\"106\">19 Jun 2026, 04:45 PM</p>\n              </td>\n              <td class=\"px-6 py-4\" data-kid=\"107\">\n                <p class=\"text-sm font-medium text-neutral-700\" data-kid=\"108\">Inversiones TechWorld</p>\n              </td>\n              <td class=\"px-6 py-4\" data-kid=\"109\">\n                <p class=\"text-sm font-medium text-neutral-700\" data-kid=\"110\">Laptop Workstation 16\"</p>\n                <p class=\"text-[11px] font-mono text-neutral-400 mt-0.5\" data-kid=\"111\">SKU: LAP-WK-16-PRO</p>\n              </td>\n              <td class=\"px-6 py-4\" data-kid=\"112\">\n                <span class=\"text-sm font-bold text-neutral-800\" data-kid=\"113\">03</span>\n                <span class=\"text-[10px] text-neutral-400 ml-1\" data-kid=\"114\">unid.</span>\n              </td>\n              <td class=\"px-6 py-4\" data-kid=\"115\">\n                <span class=\"inline-flex items-center gap-1.5 px-2.5 py-0.5 rounded-full text-xs font-bold bg-emerald-100 text-emerald-700\" data-kid=\"116\">\n                  <span class=\"w-1.5 h-1.5 rounded-full bg-emerald-500\" data-kid=\"117\"></span>\n                  Procesado\n                </span>\n              </td>\n              <td class=\"px-6 py-4 text-right\" data-kid=\"118\">\n                <button class=\"p-2 text-neutral-400 hover:text-neutral-600 rounded-lg\" data-kid=\"119\">\n                  <i class=\"ti ti-dots-vertical text-lg\" data-kid=\"120\"></i>\n                </button>\n              </td>\n            </tr>\n          </tbody>\n        </table>\n      </div>\n\n      \n      <div class=\"px-6 py-4 bg-neutral-50 border-t border-neutral-200 flex items-center justify-between\" data-kid=\"121\">\n        <p class=\"text-sm text-neutral-500\" data-kid=\"122\">Mostrando <span class=\"font-semibold text-neutral-700\" data-kid=\"123\">1 - 10</span> de <span class=\"font-semibold text-neutral-700\" data-kid=\"124\">84</span> resultados</p>\n        <div class=\"flex gap-2\" data-kid=\"125\">\n          <button class=\"px-3 py-1 border border-neutral-300 rounded text-sm font-medium text-neutral-400 cursor-not-allowed bg-white\" disabled data-kid=\"126\">Anterior</button>\n          <button class=\"px-3 py-1 border border-neutral-300 rounded text-sm font-medium text-neutral-600 bg-white hover:bg-neutral-50\" data-kid=\"127\">Siguiente</button>\n        </div>\n      </div>\n    </div>\n  </main>\n</div>",
